---
const B = import.meta.env.BASE_URL.replace(/\/$/, ''); // '/aara'
const url = (path: string) => B + path; // url('/atletas') = '/aara/atletas'
const localPath = Astro.url.pathname.slice(B.length) || '/'; // '/institucional'
const isActive = (path: string) =>
  path === '/' ? localPath === '/' : localPath === path || localPath.startsWith(path + '/');

const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Noticias", href: "/noticias" },
  { label: "CAR 2025", href: "/car-2025" },
  { label: "Institucional", href: "/institucional" },
  { label: "Clubes", href: "/clubes" },
  { label: "Delegados", href: "/delegados" },
  {
    label: "Biblioteca",
    href: "/biblioteca",
    children: [
      { label: "Calendario 2026", href: "/biblioteca/calendario" },
      { label: "Galería", href: "/biblioteca/galeria" },
      { label: "Estatuto", href: "/biblioteca/estatuto" },
      { label: "Reglamentos", href: "/biblioteca/reglamentos" },
      { label: "Formularios", href: "/biblioteca/formularios" },
    ],
  },
  {
    label: "Resultados",
    href: "/resultados",
    children: [
      { label: "Resultados de regatas", href: "/resultados" },
      { label: "Ranking de clubes", href: "/ranking-clubes" },
      { label: "Records de Ergo", href: "/records" },
    ],
  },
  { label: "Atletas", href: "/atletas" },
  { label: "Inscripciones", href: "/inscripciones" },
  { label: "Contacto", href: "/contacto" },
];
---

<header class="bg-[#0B2545] text-white sticky top-0 z-50 shadow-lg">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={B + '/'} class="flex items-center gap-3 shrink-0">
        <img src={url('/aara-logo.png')} alt="AARA" class="h-14 w-auto" />
        <div class="leading-tight">
          <div class="font-bold text-base tracking-wide">AARA</div>
          <div class="text-[10px] text-[#EFC050] uppercase tracking-widest hidden sm:block">Remo Argentina</div>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) =>
          item.children ? (
            <div class="relative group">
              <button class="flex items-center gap-1 px-3 py-2 rounded text-sm font-medium text-gray-300 hover:text-white hover:bg-white/10 transition-colors">
                {item.label}
                <svg class="w-3.5 h-3.5 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="absolute top-full left-0 mt-1 w-48 bg-white rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-1">
                {item.children.map((child) => (
                  <a href={url(child.href)} class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-[#EFC050]/20 hover:text-[#0B2545] transition-colors">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={url(item.href)}
              class={`px-3 py-2 rounded text-sm font-medium transition-colors ${
                isActive(item.href)
                  ? "bg-[#EFC050] text-[#0B2545]"
                  : "text-gray-300 hover:text-white hover:bg-white/10"
              }`}
            >
              {item.label}
            </a>
          )
        )}
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded text-gray-300 hover:text-white hover:bg-white/10 transition-colors"
        aria-label="Menú"
      >
        <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-1">
      {navItems.map((item) =>
        item.children ? (
          <div>
            <div class="px-3 py-2 text-sm font-semibold text-[#EFC050] uppercase tracking-wider">{item.label}</div>
            {item.children.map((child) => (
              <a href={child.href} class="block pl-6 pr-3 py-2 text-sm text-gray-300 hover:text-white hover:bg-white/10 rounded transition-colors">
                {child.label}
              </a>
            ))}
          </div>
        ) : (
          <a
            href={url(item.href)}
            class={`px-3 py-2 rounded text-sm font-medium transition-colors ${
              isActive(item.href)
                ? "bg-[#EFC050] text-[#0B2545]"
                : "text-gray-300 hover:text-white hover:bg-white/10"
            }`}
          >
            {item.label}
          </a>
        )
      )}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
  });
</script>
