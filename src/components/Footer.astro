---
const B = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => B + path;
---
<footer class="bg-[#0B2545] text-gray-300 mt-16">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src={url('/aara-logo.png')} alt="AARA" class="h-14 w-auto" />
          <div class="leading-tight">
            <div class="font-bold text-white text-lg">AARA</div>
            <div class="text-xs text-[#EFC050] uppercase tracking-widest">Asociación Argentina de Remeros Aficionados</div>
          </div>
        </div>
        <p class="text-sm leading-relaxed">
          Organismo rector del remo en la República Argentina. Promovemos el deporte, la competencia y los valores del remo a nivel nacional.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Accesos rápidos</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={url('/biblioteca/calendario')} class="hover:text-[#EFC050] transition-colors">Calendario 2026</a></li>
          <li><a href={url('/resultados')} class="hover:text-[#EFC050] transition-colors">Resultados</a></li>
          <li><a href={url('/clubes')} class="hover:text-[#EFC050] transition-colors">Clubes afiliados</a></li>
          <li><a href={url('/biblioteca/reglamentos')} class="hover:text-[#EFC050] transition-colors">Reglamentos</a></li>
          <li><a href={url('/biblioteca/formularios')} class="hover:text-[#EFC050] transition-colors">Formularios</a></li>
          <li><a href={url('/contacto')} class="hover:text-[#EFC050] transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Social & Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Seguinos</h3>
        <div class="flex gap-3 mb-6">
          <a href="https://www.facebook.com/aararemo" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/10 hover:bg-[#EFC050] hover:text-[#0B2545] rounded-full flex items-center justify-center transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/aara.remo" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/10 hover:bg-[#EFC050] hover:text-[#0B2545] rounded-full flex items-center justify-center transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke-width="2"/>
              <circle cx="12" cy="12" r="4" stroke-width="2"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a href="https://www.youtube.com/user/asocargremo" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/10 hover:bg-[#EFC050] hover:text-[#0B2545] rounded-full flex items-center justify-center transition-colors" aria-label="YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58a2.78 2.78 0 001.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.96A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/>
            </svg>
          </a>
        </div>
        <p class="text-sm">
          <svg class="w-4 h-4 inline-block text-[#EFC050] mr-1 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg> contacto@remoargentina.org
        </p>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-gray-500">
      <span>© {new Date().getFullYear()} AARA — Asociación Argentina de Remeros Aficionados</span>
      <a href={url('/administracion')} class="hover:text-gray-300 transition-colors">Administración</a>
    </div>
  </div>
</footer>
