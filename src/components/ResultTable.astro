---
import { atletas, toSlug } from '../data/atletas';

type R = { pos: number; club: string; atletas: string; tiempo: string };
interface Props { results: R[]; capacity?: number }
const { results, capacity } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const atletasSlugs = new Set(atletas.map(a => toSlug(a.nombre)));
---

<div class="rounded-lg overflow-hidden border border-gray-200">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 text-xs font-semibold text-gray-500 uppercase">
      <tr>
        <th class="px-3 py-2 text-center w-10">#</th>
        <th class="px-3 py-2 text-left">Club</th>
        <th class="px-3 py-2 text-left">Atletas</th>
        <th class="px-3 py-2 text-right">Tiempo</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      {results.map(r => (
        <tr class={r.pos===1?'bg-yellow-50':r.pos===2?'bg-gray-50':r.pos===3?'bg-amber-50':''}>
          <td class="px-3 py-2.5 text-center">
            {r.pos===1 && <span style="background:#EFC050" class="inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold text-white">1</span>}
            {r.pos===2 && <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-400 text-xs font-bold text-white">2</span>}
            {r.pos===3 && <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-amber-700 text-xs font-bold text-white">3</span>}
            {r.pos>3 && <span class="text-gray-400 text-xs font-medium">{r.pos}</span>}
          </td>
          <td class="px-3 py-2.5 font-semibold text-[#0B2545] text-xs">{r.club}</td>
          <td class="px-3 py-2.5 text-gray-600 text-xs leading-snug max-w-xs">
            {(() => {
              const names = r.atletas.split(' / ');
              const main = capacity ? names.slice(0, capacity) : names;
              const subs = capacity ? names.slice(capacity) : [];
              const renderName = (name: string, idx: number, arr: string[]) => {
                const slug = toSlug(name);
                const sep = idx < arr.length - 1 ? ' / ' : '';
                return atletasSlugs.has(slug)
                  ? <><a href={`${base}/atletas/${slug}`} class="text-[#134074] hover:text-[#0B2545] hover:underline font-medium transition-colors">{name}</a>{sep}</>
                  : <>{name}{sep}</>;
              };
              return (
                <>
                  <span>{main.map((n, i) => renderName(n, i, main))}</span>
                  {subs.length > 0 && (
                    <span class="text-gray-400 italic block mt-0.5">
                      Suplentes: {subs.map((n, i) => renderName(n, i, subs))}
                    </span>
                  )}
                </>
              );
            })()}
          </td>
          <td class="px-3 py-2.5 text-right font-mono text-sm font-semibold text-[#134074]">{r.tiempo}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
