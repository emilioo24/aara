---

<Layout title="Records Argentinos de Ergo — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-[#EFC050] text-sm font-medium mb-2">AARA</div>
      <h1 class="text-3xl md:text-4xl font-bold">Records Argentinos de Ergo</h1>
      <p class="text-gray-300 mt-2">Marcas oficiales en ergómetro Concept2 reconocidas por AARA · Hacé clic en una fila para ver los parciales</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12 space-y-12">

    <!-- ── Senior ── -->
    <section>
      <h2 class="text-xl font-bold text-[#0B2545] mb-5 flex items-center gap-2">
        <span class="w-1 h-6 bg-[#EFC050] rounded-full inline-block"></span>
        Categoría Senior
      </h2>
      <div class="overflow-x-auto rounded-xl shadow">
        <table class="w-full text-sm bg-white">
          <thead>
            <tr class="bg-[#0B2545] text-white text-left">
              <th class="px-5 py-4 font-semibold">Distancia</th>
              <th class="px-5 py-4 font-semibold">Masculino — Tiempo</th>
              <th class="px-5 py-4 font-semibold hidden sm:table-cell">Watts</th>
              <th class="px-5 py-4 font-semibold hidden md:table-cell">Atleta</th>
              <th class="px-5 py-4 font-semibold hidden lg:table-cell">Club</th>
              <th class="px-5 py-4 font-semibold hidden md:table-cell">Año</th>
              <th class="px-5 py-4 font-semibold border-l border-white/20">Femenino — Tiempo</th>
              <th class="px-5 py-4 font-semibold hidden sm:table-cell">Watts</th>
              <th class="px-5 py-4 font-semibold hidden md:table-cell">Atleta</th>
              <th class="px-5 py-4 font-semibold hidden lg:table-cell">Club</th>
              <th class="px-5 py-4 font-semibold hidden md:table-cell">Año</th>
            </tr>
          </thead>
          <tbody>
            {records.map((r, i) => (
              <>
                <tr
                  data-toggle={`sr-${i}`}
                  class={`cursor-pointer hover:bg-sky-50/60 transition-colors select-none ${i % 2 === 0 ? 'bg-gray-50' : 'bg-white'}`}
                >
                  <td class="px-5 py-3.5">
                    <div class="flex items-center gap-2">
                      <span class="font-bold text-[#0B2545]">{r.distancia}</span>
                      <svg data-chevron class="w-3.5 h-3.5 text-gray-400 transition-transform duration-200 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                      </svg>
                    </div>
                  </td>
                  <td class="px-5 py-3.5 font-mono font-bold text-[#134074]">{r.masculino.tiempo}</td>
                  <td class="px-5 py-3.5 text-gray-500 hidden sm:table-cell">{r.masculino.watts ?? "—"} W</td>
                  <td class="px-5 py-3.5 text-gray-600 hidden md:table-cell">{r.masculino.nombre}</td>
                  <td class="px-5 py-3.5 text-gray-400 text-xs hidden lg:table-cell">{r.masculino.club}</td>
                  <td class="px-5 py-3.5 text-gray-400 text-xs hidden md:table-cell">{r.masculino.fecha}</td>
                  <td class="px-5 py-3.5 font-mono font-bold text-[#134074] border-l border-gray-100">{r.femenino.tiempo}</td>
                  <td class="px-5 py-3.5 text-gray-500 hidden sm:table-cell">{r.femenino.watts ?? "—"} W</td>
                  <td class="px-5 py-3.5 text-gray-600 hidden md:table-cell">{r.femenino.nombre}</td>
                  <td class="px-5 py-3.5 text-gray-400 text-xs hidden lg:table-cell">{r.femenino.club}</td>
                  <td class="px-5 py-3.5 text-gray-400 text-xs hidden md:table-cell">{r.femenino.fecha}</td>
                </tr>

                <!-- Expand row -->
                <tr id={`sr-${i}`} class="hidden">
                  <td colspan="11" class="px-5 pt-3 pb-5 bg-[#0B2545]/[0.03] border-b border-gray-100">
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">

                      <!-- Masculino -->
                      <div>
                        <div class="flex flex-wrap items-center gap-2 mb-3">
                          <span class="w-2 h-2 rounded-full bg-blue-500 shrink-0"></span>
                          <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">Masculino</span>
                          <span class="font-mono font-bold text-[#0B2545]">{r.masculino.tiempo}</span>
                          {r.masculino.watts && <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">{r.masculino.watts} W</span>}
                          {r.masculino.spm && <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">{r.masculino.spm} spm</span>}
                        </div>
                        {r.masculino.splits.length === 1 ? (
                          <div class="grid grid-cols-2 gap-2">
                            <div class="bg-white rounded-xl p-4 text-center border border-gray-100 shadow-sm">
                              <div class="text-[10px] text-gray-400 mb-1 uppercase tracking-wider">Tiempo total</div>
                              <div class="font-mono font-bold text-[#0B2545] text-xl">{r.masculino.tiempo}</div>
                            </div>
                            {r.masculino.watts && (
                              <div class="bg-white rounded-xl p-4 text-center border border-gray-100 shadow-sm">
                                <div class="text-[10px] text-gray-400 mb-1 uppercase tracking-wider">Potencia media</div>
                                <div class="font-mono font-bold text-[#0B2545] text-xl">{r.masculino.watts} W</div>
                              </div>
                            )}
                          </div>
                        ) : (
                          <div>
                            <div class="text-[10px] text-gray-400 uppercase tracking-wider mb-2">Parciales cada 500m</div>
                            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                              {r.masculino.splits.map((s, idx) => (
                                <div class="bg-white rounded-xl p-3 text-center border border-gray-100 shadow-sm">
                                  <div class="text-[10px] text-gray-400 mb-1">{segLabel(idx)}</div>
                                  <div class="font-mono font-bold text-[#0B2545] text-sm">{s.tiempo}</div>
                                  {s.watts && <div class="text-[10px] text-gray-400 mt-1">{s.watts} W</div>}
                                </div>
                              ))}
                            </div>
                          </div>
                        )}
                      </div>

                      <!-- Femenino -->
                      <div>
                        <div class="flex flex-wrap items-center gap-2 mb-3">
                          <span class="w-2 h-2 rounded-full bg-pink-400 shrink-0"></span>
                          <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">Femenino</span>
                          <span class="font-mono font-bold text-[#0B2545]">{r.femenino.tiempo}</span>
                          {r.femenino.watts && <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">{r.femenino.watts} W</span>}
                          {r.femenino.spm && <span class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">{r.femenino.spm} spm</span>}
                        </div>
                        {r.femenino.splits.length === 1 ? (
                          <div class="grid grid-cols-2 gap-2">
                            <div class="bg-white rounded-xl p-4 text-center border border-gray-100 shadow-sm">
                              <div class="text-[10px] text-gray-400 mb-1 uppercase tracking-wider">Tiempo total</div>
                              <div class="font-mono font-bold text-[#0B2545] text-xl">{r.femenino.tiempo}</div>
                            </div>
                            {r.femenino.watts && (
                              <div class="bg-white rounded-xl p-4 text-center border border-gray-100 shadow-sm">
                                <div class="text-[10px] text-gray-400 mb-1 uppercase tracking-wider">Potencia media</div>
                                <div class="font-mono font-bold text-[#0B2545] text-xl">{r.femenino.watts} W</div>
                              </div>
                            )}
                          </div>
                        ) : (
                          <div>
                            <div class="text-[10px] text-gray-400 uppercase tracking-wider mb-2">Parciales cada 500m</div>
                            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                              {r.femenino.splits.map((s, idx) => (
                                <div class="bg-white rounded-xl p-3 text-center border border-gray-100 shadow-sm">
                                  <div class="text-[10px] text-gray-400 mb-1">{segLabel(idx)}</div>
                                  <div class="font-mono font-bold text-[#0B2545] text-sm">{s.tiempo}</div>
                                  {s.watts && <div class="text-[10px] text-gray-400 mt-1">{s.watts} W</div>}
                                </div>
                              ))}
                            </div>
                          </div>
                        )}
                      </div>

                    </div>
                  </td>
                </tr>
              </>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400 mt-2 ml-1">Ergómetro Concept2 · Remo indoor · Peso libre</p>
    </section>

    <!-- ── Otras categorías ── -->
    <section>
      <h2 class="text-xl font-bold text-[#0B2545] mb-5 flex items-center gap-2">
        <span class="w-1 h-6 bg-[#EFC050] rounded-full inline-block"></span>
        Otras categorías
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {categorias.map((cat, catIdx) => (
          <div class="bg-white rounded-xl shadow overflow-hidden">
            <div class={`bg-gradient-to-r ${cat.color} text-white px-5 py-3`}>
              <span class="font-bold text-sm">{cat.label}</span>
            </div>
            <!-- Header row -->
            <div class="flex items-center px-4 py-2 bg-gray-50 border-b border-gray-100 text-[10px] text-gray-400 uppercase tracking-wider">
              <span class="w-14 shrink-0">Dist.</span>
              <span class="flex-1">Tiempo</span>
              <span class="w-10 text-right">Año</span>
              <span class="w-5"></span>
            </div>
            <div class="divide-y divide-gray-50">
              {cat.records.map((r, rIdx) => (
                <div>
                  <div
                    data-toggle={`cat-${catIdx}-${rIdx}`}
                    class="flex items-center px-4 py-3 cursor-pointer hover:bg-sky-50/50 transition-colors select-none gap-1"
                  >
                    <span class="font-bold text-[#0B2545] text-sm w-14 shrink-0">{r.distancia}</span>
                    <span class="font-mono font-bold text-[#134074] text-sm flex-1">{r.tiempo}</span>
                    <span class="text-gray-400 text-xs w-10 text-right">{r.fecha}</span>
                    <svg data-chevron class="w-3.5 h-3.5 text-gray-300 transition-transform duration-200 shrink-0 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                    </svg>
                  </div>
                  <div id={`cat-${catIdx}-${rIdx}`} class="hidden px-4 pt-2 pb-4 bg-[#0B2545]/[0.03]">
                    {r.splits.length === 1 ? (
                      <div class="grid grid-cols-2 gap-2">
                        <div class="bg-white rounded-xl p-3 text-center border border-gray-100 shadow-sm">
                          <div class="text-[10px] text-gray-400 mb-1 uppercase tracking-wider">Tiempo total</div>
                          <div class="font-mono font-bold text-[#0B2545] text-base">{r.tiempo}</div>
                        </div>
                        {r.splits[0].watts && (
                          <div class="bg-white rounded-xl p-3 text-center border border-gray-100 shadow-sm">
                            <div class="text-[10px] text-gray-400 mb-1 uppercase tracking-wider">Potencia</div>
                            <div class="font-mono font-bold text-[#0B2545] text-base">{r.splits[0].watts} W</div>
                          </div>
                        )}
                      </div>
                    ) : (
                      <div>
                        <div class="text-[10px] text-gray-400 uppercase tracking-wider mb-2">Parciales cada 500m</div>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-1.5">
                          {r.splits.map((s, idx) => (
                            <div class="bg-white rounded-lg p-2.5 text-center border border-gray-100 shadow-sm">
                              <div class="text-[9px] text-gray-400 mb-0.5">{segLabel(idx)}</div>
                              <div class="font-mono font-bold text-[#0B2545] text-xs">{s.tiempo}</div>
                              {s.watts && <div class="text-[9px] text-gray-400 mt-0.5">{s.watts} W</div>}
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── CTA ── -->
    <div class="bg-[#EFC050]/10 border border-[#EFC050]/30 rounded-xl p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <p class="font-semibold text-[#0B2545]">¿Tenés una marca para homologar?</p>
        <p class="text-sm text-gray-600 mt-1">Enviá el video y el archivo .erg de Concept2 a la secretaría de AARA para solicitar la homologación del record.</p>
      </div>
      <a href={url('/contacto')} class="shrink-0 bg-[#0B2545] hover:bg-[#134074] text-white font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm">
        Contactar secretaría
      </a>
    </div>

  </div>
</Layout>

<script>
  document.querySelectorAll<HTMLElement>('[data-toggle]').forEach(el => {
    el.addEventListener('click', () => {
      const id = el.dataset.toggle!;
      const panel = document.getElementById(id)!;
      const chevron = el.querySelector<SVGElement>('[data-chevron]')!;
      const opening = panel.classList.contains('hidden');
      panel.classList.toggle('hidden', !opening);
      chevron.style.transform = opening ? 'rotate(90deg)' : '';
    });
  });
</script>
