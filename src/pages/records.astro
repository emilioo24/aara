import Layout from '../layouts/Layout.astro';

type Split = { tiempo: string; watts?: number };

type Registro = {
  nombre: string;
  club: string;
  tiempo: string;
  watts?: number;
  spm?: number;
  fecha: string;
  splits: Split[];
};

type DistanciaRecord = {
  distancia: string;
  masculino: Registro;
  femenino: Registro;
};

type CatRecord = {
  distancia: string;
  nombre: string;
  club: string;
  tiempo: string;
  fecha: string;
  splits: Split[];
};

function segLabel(idx: number): string {
  const s = idx * 500;
  const e = (idx + 1) * 500;
  const fmt = (m: number) => m === 0 ? '0' : m >= 1000 ? `${m / 1000}k` : `${m}m`;
  return `${fmt(s)}–${fmt(e)}`;
}

