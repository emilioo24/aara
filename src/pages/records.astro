---
import Layout from '../layouts/Layout.astro';
import { seniorRecords, categorias } from '../data/records';

const B = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => B + path;

const seniorPLCats = categorias.filter(c => c.label.startsWith('Senior Peso Ligero'));
const otrasCats    = categorias.filter(c => !c.label.startsWith('Senior Peso Ligero'));

function segLabel(idx: number): string {
  const s = idx * 500;
  const e = (idx + 1) * 500;
  const fmt = (m: number) => m === 0 ? '0' : m >= 1000 ? `${m / 1000}k` : `${m}m`;
  return `${fmt(s)}–${fmt(e)}`;
}
---

<Layout title="Records Argentinos de Ergo — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-[#EFC050] text-sm font-medium mb-2">AARA</div>
      <h1 class="text-3xl md:text-4xl font-bold">Records Argentinos de Ergo</h1>
      <p class="text-gray-300 mt-2">Marcas oficiales en ergómetro Concept2 reconocidas por AARA · Hacé clic en una fila para ver los parciales</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12 space-y-12">

    <!-- ── Senior ── -->
    <section>
      <h2 class="text-xl font-bold text-[#0B2545] mb-5 flex items-center gap-2">
        <span class="w-1 h-6 bg-[#EFC050] rounded-full inline-block"></span>
        Categoría Senior
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">

        <!-- Senior Masculino -->
        <div class="bg-white rounded-xl shadow overflow-hidden">
          <div class="bg-gradient-to-r from-[#0B2545] to-[#134074] text-white px-5 py-4 flex items-center gap-3">
            <svg class="w-5 h-5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <span class="font-bold text-base">Senior Masculino</span>
          </div>
          <div class="flex items-center px-5 py-2 bg-gray-50 border-b border-gray-100 text-[10px] text-gray-400 uppercase tracking-wider">
            <span class="w-16 shrink-0">Dist.</span>
            <span class="flex-1">Tiempo</span>
            <span class="hidden sm:block w-16">RPM</span>
            <span class="hidden md:block flex-1">Atleta</span>
            <span class="w-12 text-right">Año</span>
            <span class="w-5"></span>
          </div>
          <div class="divide-y divide-gray-50">
            {seniorRecords.map((r, i) => (
              <div>
                <div data-toggle={`srm-${i}`} class="flex items-center px-5 py-3.5 cursor-pointer hover:bg-sky-50/50 transition-colors select-none gap-1">
                  <span class="font-bold text-[#0B2545] w-16 shrink-0">{r.distancia}</span>
                  <span class="font-mono font-bold text-[#134074] flex-1 text-base">{r.masculino.tiempo}</span>
                  <span class="hidden sm:block text-gray-500 text-sm w-16">{r.masculino.rpm ? `${r.masculino.rpm} rpm` : '—'}</span>
                  {r.masculino.slug
                    ? <a href={`${B}/atletas/${r.masculino.slug}`} class="hidden md:block text-[#13A8D4] hover:underline text-sm flex-1 truncate" onclick="event.stopPropagation()">{r.masculino.nombre}</a>
                    : <span class="hidden md:block text-gray-400 text-sm flex-1 truncate">{r.masculino.nombre}</span>
                  }
                  <span class="text-gray-400 text-xs w-12 text-right">{r.masculino.fecha}</span>
                  <svg data-chevron class="w-3.5 h-3.5 text-gray-300 transition-transform duration-200 shrink-0 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
                <div id={`srm-${i}`} class="hidden px-5 pt-3 pb-4 bg-[#0B2545]/[0.03]">
                  <div class="flex flex-wrap gap-2 mb-3 text-xs text-gray-500">
                    {r.masculino.rpm && <span class="bg-gray-100 px-2 py-0.5 rounded-full">{r.masculino.rpm} rpm</span>}
                    {r.masculino.club !== '—' && <span class="bg-gray-100 px-2 py-0.5 rounded-full">{r.masculino.club}</span>}
                  </div>
                  {r.masculino.splits.length === 1 ? (
                    <div class="bg-white rounded-xl p-3 text-center border border-gray-100 shadow-sm inline-block min-w-[8rem]">
                      <div class="text-[10px] text-gray-400 mb-1 uppercase tracking-wider">Tiempo total</div>
                      <div class="font-mono font-bold text-[#0B2545] text-lg">{r.masculino.tiempo}</div>
                    </div>
                  ) : (
                    <div>
                      <div class="text-[10px] text-gray-400 uppercase tracking-wider mb-2">Parciales cada 500m</div>
                      <div class="grid grid-cols-2 sm:grid-cols-4 gap-1.5">
                        {r.masculino.splits.map((s, idx) => (
                          <div class="bg-white rounded-lg p-2.5 text-center border border-gray-100 shadow-sm">
                            <div class="text-[9px] text-gray-400 mb-0.5">{segLabel(idx)}</div>
                            <div class="font-mono font-bold text-[#0B2545] text-sm">{s.tiempo}</div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Senior Femenino -->
        <div class="bg-white rounded-xl shadow overflow-hidden">
          <div class="bg-gradient-to-r from-pink-600 to-pink-800 text-white px-5 py-4 flex items-center gap-3">
            <svg class="w-5 h-5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <span class="font-bold text-base">Senior Femenino</span>
          </div>
          <div class="flex items-center px-5 py-2 bg-gray-50 border-b border-gray-100 text-[10px] text-gray-400 uppercase tracking-wider">
            <span class="w-16 shrink-0">Dist.</span>
            <span class="flex-1">Tiempo</span>
            <span class="hidden sm:block w-16">RPM</span>
            <span class="hidden md:block flex-1">Atleta</span>
            <span class="w-12 text-right">Año</span>
            <span class="w-5"></span>
          </div>
          <div class="divide-y divide-gray-50">
            {seniorRecords.map((r, i) => (
              <div>
                <div data-toggle={`srf-${i}`} class="flex items-center px-5 py-3.5 cursor-pointer hover:bg-pink-50/50 transition-colors select-none gap-1">
                  <span class="font-bold text-[#0B2545] w-16 shrink-0">{r.distancia}</span>
                  <span class="font-mono font-bold text-pink-700 flex-1 text-base">{r.femenino.tiempo}</span>
                  <span class="hidden sm:block text-gray-500 text-sm w-16">{r.femenino.rpm ? `${r.femenino.rpm} rpm` : '—'}</span>
                  {r.femenino.slug
                    ? <a href={`${B}/atletas/${r.femenino.slug}`} class="hidden md:block text-[#13A8D4] hover:underline text-sm flex-1 truncate" onclick="event.stopPropagation()">{r.femenino.nombre}</a>
                    : <span class="hidden md:block text-gray-400 text-sm flex-1 truncate">{r.femenino.nombre}</span>
                  }
                  <span class="text-gray-400 text-xs w-12 text-right">{r.femenino.fecha}</span>
                  <svg data-chevron class="w-3.5 h-3.5 text-gray-300 transition-transform duration-200 shrink-0 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
                <div id={`srf-${i}`} class="hidden px-5 pt-3 pb-4 bg-pink-50/30">
                  <div class="flex flex-wrap gap-2 mb-3 text-xs text-gray-500">
                    {r.femenino.rpm && <span class="bg-gray-100 px-2 py-0.5 rounded-full">{r.femenino.rpm} rpm</span>}
                    {r.femenino.club !== '—' && <span class="bg-gray-100 px-2 py-0.5 rounded-full">{r.femenino.club}</span>}
                  </div>
                  {r.femenino.splits.length === 1 ? (
                    <div class="bg-white rounded-xl p-3 text-center border border-gray-100 shadow-sm inline-block min-w-[8rem]">
                      <div class="text-[10px] text-gray-400 mb-1 uppercase tracking-wider">Tiempo total</div>
                      <div class="font-mono font-bold text-[#0B2545] text-lg">{r.femenino.tiempo}</div>
                    </div>
                  ) : (
                    <div>
                      <div class="text-[10px] text-gray-400 uppercase tracking-wider mb-2">Parciales cada 500m</div>
                      <div class="grid grid-cols-2 sm:grid-cols-4 gap-1.5">
                        {r.femenino.splits.map((s, idx) => (
                          <div class="bg-white rounded-lg p-2.5 text-center border border-gray-100 shadow-sm">
                            <div class="text-[9px] text-gray-400 mb-0.5">{segLabel(idx)}</div>
                            <div class="font-mono font-bold text-[#0B2545] text-sm">{s.tiempo}</div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>

      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mt-6 mb-3 ml-1">Peso Ligero</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {seniorPLCats.map((cat, catIdx) => (
          <div class="bg-white rounded-xl shadow overflow-hidden">
            <div class={`bg-gradient-to-r ${cat.color} text-white px-5 py-3`}>
              <span class="font-bold text-sm">{cat.label}</span>
            </div>
            <div class="flex items-center px-4 py-2 bg-gray-50 border-b border-gray-100 text-[10px] text-gray-400 uppercase tracking-wider">
              <span class="w-14 shrink-0">Dist.</span>
              <span class="flex-1">Tiempo</span>
              <span class="hidden sm:block w-14">RPM</span>
              <span class="hidden lg:block flex-1">Atleta</span>
              <span class="w-10 text-right">Año</span>
              <span class="w-5"></span>
            </div>
            <div class="divide-y divide-gray-50">
              {cat.records.map((r, rIdx) => (
                <div>
                  <div data-toggle={`spl-${catIdx}-${rIdx}`} class="flex items-center px-4 py-3 cursor-pointer hover:bg-sky-50/50 transition-colors select-none gap-1">
                    <span class="font-bold text-[#0B2545] text-sm w-14 shrink-0">{r.distancia}</span>
                    <span class="font-mono font-bold text-[#134074] text-sm flex-1">{r.tiempo}</span>
                    <span class="hidden sm:block text-gray-500 text-xs w-14">{r.rpm ? `${r.rpm} rpm` : '—'}</span>
                    {r.slug
                      ? <a href={`${B}/atletas/${r.slug}`} class="hidden lg:block text-[#13A8D4] hover:underline text-xs flex-1 truncate" onclick="event.stopPropagation()">{r.nombre}</a>
                      : <span class="hidden lg:block text-gray-400 text-xs flex-1 truncate">{r.nombre}</span>
                    }
                    <span class="text-gray-400 text-xs w-10 text-right">{r.fecha}</span>
                    <svg data-chevron class="w-3.5 h-3.5 text-gray-300 transition-transform duration-200 shrink-0 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                    </svg>
                  </div>
                  <div id={`spl-${catIdx}-${rIdx}`} class="hidden px-4 pt-2 pb-4 bg-[#0B2545]/[0.03]">
                    <div class="flex flex-wrap gap-2 mb-3 text-xs text-gray-500">
                      {r.rpm && <span class="bg-gray-100 px-2 py-0.5 rounded-full">{r.rpm} rpm</span>}
                      {r.club !== '—' && <span class="bg-gray-100 px-2 py-0.5 rounded-full">{r.club}</span>}
                      {r.nombre !== '—' && r.slug && (
                        <a href={`${B}/atletas/${r.slug}`} class="bg-[#13A8D4]/10 text-[#13A8D4] px-2 py-0.5 rounded-full hover:underline">{r.nombre}</a>
                      )}
                    </div>
                    {r.splits.length === 1 ? (
                      <div class="bg-white rounded-xl p-3 text-center border border-gray-100 shadow-sm inline-block min-w-[7rem]">
                        <div class="text-[10px] text-gray-400 mb-1 uppercase tracking-wider">Tiempo total</div>
                        <div class="font-mono font-bold text-[#0B2545] text-base">{r.tiempo}</div>
                      </div>
                    ) : (
                      <div>
                        <div class="text-[10px] text-gray-400 uppercase tracking-wider mb-2">Parciales cada 500m</div>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-1.5">
                          {r.splits.map((s, idx) => (
                            <div class="bg-white rounded-lg p-2.5 text-center border border-gray-100 shadow-sm">
                              <div class="text-[9px] text-gray-400 mb-0.5">{segLabel(idx)}</div>
                              <div class="font-mono font-bold text-[#0B2545] text-xs">{s.tiempo}</div>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <p class="text-xs text-gray-400 mt-2 ml-1">Ergómetro Concept2 · Remo indoor · Peso libre</p>
    </section>

    <!-- ── Otras categorías ── -->
    <section>
      <h2 class="text-xl font-bold text-[#0B2545] mb-5 flex items-center gap-2">
        <span class="w-1 h-6 bg-[#EFC050] rounded-full inline-block"></span>
        Otras categorías
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {otrasCats.map((cat, catIdx) => (
          <div class="bg-white rounded-xl shadow overflow-hidden">
            <div class={`bg-gradient-to-r ${cat.color} text-white px-5 py-3`}>
              <span class="font-bold text-sm">{cat.label}</span>
            </div>
            <div class="flex items-center px-4 py-2 bg-gray-50 border-b border-gray-100 text-[10px] text-gray-400 uppercase tracking-wider">
              <span class="w-14 shrink-0">Dist.</span>
              <span class="flex-1">Tiempo</span>
              <span class="hidden sm:block w-14">RPM</span>
              <span class="hidden lg:block flex-1">Atleta</span>
              <span class="w-10 text-right">Año</span>
              <span class="w-5"></span>
            </div>
            <div class="divide-y divide-gray-50">
              {cat.records.map((r, rIdx) => (
                <div>
                  <div data-toggle={`cat-${catIdx}-${rIdx}`} class="flex items-center px-4 py-3 cursor-pointer hover:bg-sky-50/50 transition-colors select-none gap-1">
                    <span class="font-bold text-[#0B2545] text-sm w-14 shrink-0">{r.distancia}</span>
                    <span class="font-mono font-bold text-[#134074] text-sm flex-1">{r.tiempo}</span>
                    <span class="hidden sm:block text-gray-500 text-xs w-14">{r.rpm ? `${r.rpm} rpm` : '—'}</span>
                    {r.slug
                      ? <a href={`${B}/atletas/${r.slug}`} class="hidden lg:block text-[#13A8D4] hover:underline text-xs flex-1 truncate" onclick="event.stopPropagation()">{r.nombre}</a>
                      : <span class="hidden lg:block text-gray-400 text-xs flex-1 truncate">{r.nombre}</span>
                    }
                    <span class="text-gray-400 text-xs w-10 text-right">{r.fecha}</span>
                    <svg data-chevron class="w-3.5 h-3.5 text-gray-300 transition-transform duration-200 shrink-0 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                    </svg>
                  </div>
                  <div id={`cat-${catIdx}-${rIdx}`} class="hidden px-4 pt-2 pb-4 bg-[#0B2545]/[0.03]">
                    <div class="flex flex-wrap gap-2 mb-3 text-xs text-gray-500">
                      {r.rpm && <span class="bg-gray-100 px-2 py-0.5 rounded-full">{r.rpm} rpm</span>}
                      {r.club !== '—' && <span class="bg-gray-100 px-2 py-0.5 rounded-full">{r.club}</span>}
                      {r.nombre !== '—' && r.slug && (
                        <a href={`${B}/atletas/${r.slug}`} class="bg-[#13A8D4]/10 text-[#13A8D4] px-2 py-0.5 rounded-full hover:underline">{r.nombre}</a>
                      )}
                    </div>
                    {r.splits.length === 1 ? (
                      <div class="bg-white rounded-xl p-3 text-center border border-gray-100 shadow-sm inline-block min-w-[7rem]">
                        <div class="text-[10px] text-gray-400 mb-1 uppercase tracking-wider">Tiempo total</div>
                        <div class="font-mono font-bold text-[#0B2545] text-base">{r.tiempo}</div>
                      </div>
                    ) : (
                      <div>
                        <div class="text-[10px] text-gray-400 uppercase tracking-wider mb-2">Parciales cada 500m</div>
                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-1.5">
                          {r.splits.map((s, idx) => (
                            <div class="bg-white rounded-lg p-2.5 text-center border border-gray-100 shadow-sm">
                              <div class="text-[9px] text-gray-400 mb-0.5">{segLabel(idx)}</div>
                              <div class="font-mono font-bold text-[#0B2545] text-xs">{s.tiempo}</div>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── CTA ── -->
    <div class="bg-[#EFC050]/10 border border-[#EFC050]/30 rounded-xl p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <p class="font-semibold text-[#0B2545]">¿Tenés una marca para homologar?</p>
        <p class="text-sm text-gray-600 mt-1">Enviá el video y el archivo .erg de Concept2 a la secretaría de AARA para solicitar la homologación del record.</p>
      </div>
      <a href={url('/contacto')} class="shrink-0 bg-[#0B2545] hover:bg-[#134074] text-white font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm">
        Contactar secretaría
      </a>
    </div>

  </div>
</Layout>

<script>
  document.querySelectorAll<HTMLElement>('[data-toggle]').forEach(el => {
    el.addEventListener('click', () => {
      const id = el.dataset.toggle!;
      const panel = document.getElementById(id);
      if (!panel) return;
      const chevron = el.querySelector<SVGElement>('[data-chevron]')!;
      const opening = panel.classList.contains('hidden');
      panel.classList.toggle('hidden', !opening);
      chevron.style.transform = opening ? 'rotate(90deg)' : '';
    });
  });
</script>
