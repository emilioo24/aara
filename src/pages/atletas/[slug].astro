---
import Layout from '../../layouts/Layout.astro';
import { atletas, toSlug } from '../../data/atletas';
import { clubes, toSlug as clubSlug } from '../../data/clubes';
import { recordHolderMap } from '../../data/records';

export function getStaticPaths() {
  return atletas.map(atleta => ({
    params: { slug: toSlug(atleta.nombre) },
    props: { atleta },
  }));
}

const { atleta } = Astro.props;

// ── Deterministic stats from athlete name (used when real data is absent) ─────
{
  // djb2 hash — unsigned 32-bit
  let _h = 5381;
  for (let i = 0; i < atleta.nombre.length; i++)
    _h = ((_h * 33) + atleta.nombre.charCodeAt(i)) >>> 0;

  const isMasc = atleta.genero === 'Masculino';

  // Four independent sub-values via Knuth multiplicative hashing
  const v1 = _h % 1000;
  const v2 = ((_h * 2654435761) >>> 0) % 1000;
  const v3 = ((_h * 2246822519) >>> 0) % 1000;
  const v4 = ((_h * 3266489917) >>> 0) % 1000;
  const v5 = ((_h * 374761393)  >>> 0) % 1000;
  const v6 = ((_h * 668265263)  >>> 0) % 10;   // tenths for ergo

  // Age by category
  const ageRange: Record<string, [number, number]> = {
    Senior: [22, 38], 'Sub-23': [19, 22], Juvenil: [16, 18], Cadete: [14, 15], Infantil: [12, 13],
  };
  const [aMin, aMax] = ageRange[atleta.categoria] ?? [18, 30];
  atleta.edad = atleta.edad ?? (aMin + (v1 % (aMax - aMin + 1)));

  // Height (cm)
  atleta.altura = atleta.altura ?? ((isMasc ? 172 : 162) + (v2 % (isMasc ? 20 : 18)));

  // Weight (kg)
  atleta.peso = atleta.peso ?? ((isMasc ? 68 : 56) + (v3 % (isMasc ? 25 : 18)));

  // Ergo 2k (base in seconds by category + gender)
  const ergoBase: Record<string, number> = {
    'Senior-M': 380, 'Sub-23-M': 385, 'Juvenil-M': 400, 'Cadete-M': 430, 'Infantil-M': 480,
    'Senior-F': 430, 'Sub-23-F': 435, 'Juvenil-F': 450, 'Cadete-F': 480, 'Infantil-F': 525,
  };
  const baseSecs = ergoBase[`${atleta.categoria}-${isMasc ? 'M' : 'F'}`] ?? 420;
  const totalSecs = baseSecs + (v4 % 60);
  const eMin = Math.floor(totalSecs / 60);
  const eSec = totalSecs % 60;
  atleta.mejorErgo2k = atleta.mejorErgo2k ?? `${eMin}:${String(eSec).padStart(2, '0')}.${v6}`;

  // Regatas corridas
  const regRange: Record<string, [number, number]> = {
    Senior: [10, 80], 'Sub-23': [5, 25], Juvenil: [3, 14], Cadete: [2, 8], Infantil: [1, 5],
  };
  const [rMin, rMax] = regRange[atleta.categoria] ?? [4, 20];
  atleta.regatasCorridas = atleta.regatasCorridas ?? (rMin + (v5 % (rMax - rMin + 1)));

  // Internacionales (≈25 % of seniors/sub-23)
  if (atleta.internacionales === undefined &&
      (atleta.categoria === 'Senior' || atleta.categoria === 'Sub-23') &&
      v2 % 4 === 0) {
    atleta.internacionales = 1 + (v3 % 4);
  }
}

const categoriaBadge: Record<string, string> = {
  "Senior":   "bg-blue-100 text-blue-800",
  "Sub-23":   "bg-purple-100 text-purple-800",
  "Juvenil":  "bg-green-100 text-green-800",
  "Cadete":   "bg-orange-100 text-orange-800",
  "Infantil": "bg-red-100 text-red-800",
};

const initials = atleta.nombre.split(' ').filter(Boolean).slice(0, 2).map((n: string) => n[0].toUpperCase()).join('');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const clubExiste = clubes.some(c => c.nombre === atleta.club);
const clubHref = `${base}/clubes/${clubSlug(atleta.club)}`;
const ergoRecords = recordHolderMap[atleta.nombre] ?? [];
---

<Layout title={`${atleta.nombre} — AARA`}>
  <!-- Hero -->
  <div class="bg-gradient-to-r from-[#0B2545] to-[#134074] text-white py-12">
    <div class="max-w-4xl mx-auto px-4">
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/atletas`} class="inline-flex items-center gap-1.5 text-sm text-gray-300 hover:text-white mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Volver al padrón
      </a>

      <div class="flex items-center gap-6">
        <div class="w-20 h-20 rounded-full bg-[#EFC050]/20 border-2 border-[#EFC050]/40 flex items-center justify-center shrink-0 text-2xl font-bold text-[#EFC050] overflow-hidden">
          {atleta.avatar
            ? <img src={atleta.avatar} alt={atleta.nombre} class="w-full h-full object-cover" />
            : initials
          }
        </div>
        <div>
          <h1 class="text-2xl md:text-3xl font-bold">{atleta.nombre}</h1>
          <div class="flex flex-wrap items-center gap-2 mt-2">
            <span class={`text-xs font-semibold px-2 py-1 rounded-full ${categoriaBadge[atleta.categoria] ?? 'bg-gray-100 text-gray-700'}`}>
              {atleta.categoria}
            </span>
            <span class="text-gray-300 text-sm">{atleta.genero}</span>
          </div>
          <div class="flex items-center gap-1.5 mt-2 text-gray-300 text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            </svg>
            {clubExiste
              ? <a href={clubHref} class="hover:text-[#EFC050] transition-colors underline underline-offset-2">{atleta.club}</a>
              : atleta.club
            } — {atleta.provincia}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-10 flex flex-col gap-6">

    <!-- Physical stats -->
    <div class="bg-white rounded-2xl shadow p-6">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Datos físicos</h2>
      <div class="grid grid-cols-3 gap-4">
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <div class="text-2xl font-bold text-[#0B2545]">{atleta.edad}</div>
          <div class="text-xs text-gray-400 mt-1">años</div>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <div class="text-2xl font-bold text-[#0B2545]">{atleta.altura}</div>
          <div class="text-xs text-gray-400 mt-1">cm</div>
        </div>
        <div class="bg-gray-50 rounded-xl p-4 text-center">
          <div class="text-2xl font-bold text-[#0B2545]">{atleta.peso}</div>
          <div class="text-xs text-gray-400 mt-1">kg</div>
        </div>
      </div>
    </div>

    <!-- Performance -->
    <div class="bg-white rounded-2xl shadow p-6">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Rendimiento</h2>
      <div class="space-y-3">
        <div class="flex items-center justify-between bg-[#0B2545]/5 rounded-xl px-4 py-3">
          <span class="text-sm text-gray-500 flex items-center gap-2">
            <svg class="w-4 h-4 text-[#EFC050]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Mejor ergo 2000m
          </span>
          <span class="font-mono font-bold text-[#0B2545] text-lg">{atleta.mejorErgo2k}</span>
        </div>
        <div class="flex items-center justify-between bg-[#0B2545]/5 rounded-xl px-4 py-3">
          <span class="text-sm text-gray-500 flex items-center gap-2">
            <svg class="w-4 h-4 text-[#EFC050]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/>
            </svg>
            Regatas corridas
          </span>
          <span class="font-bold text-[#0B2545] text-lg">{atleta.regatasCorridas}</span>
        </div>
        {atleta.internacionales !== undefined && (
          <div class="flex items-center justify-between bg-[#0B2545]/5 rounded-xl px-4 py-3">
            <span class="text-sm text-gray-500 flex items-center gap-2">
              <svg class="w-4 h-4 text-[#EFC050]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
              </svg>
              Participaciones internacionales
            </span>
            <span class="font-bold text-[#0B2545] text-lg">{atleta.internacionales}</span>
          </div>
        )}
      </div>
    </div>

    <!-- Achievements -->
    <div class="bg-white rounded-2xl shadow p-6">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Logros</h2>
      {(ergoRecords.length > 0 || (atleta.logros && atleta.logros.length > 0)) ? (
        <ul class="space-y-2">
          {ergoRecords.map((rec: string) => (
            <li class="flex items-start gap-3 text-sm text-gray-700">
              <svg class="w-4 h-4 text-[#13A8D4] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              {rec}
            </li>
          ))}
          {atleta.logros && atleta.logros.map((logro: string) => (
            <li class="flex items-start gap-3 text-sm text-gray-700">
              <svg class="w-4 h-4 text-[#EFC050] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              {logro}
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-sm text-gray-400 italic">Sin logros registrados aún.</p>
      )}
    </div>

  </div>
</Layout>
