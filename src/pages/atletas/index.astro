---
import Layout from '../../layouts/Layout.astro';
import { atletas, toSlug } from '../../data/atletas';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categorias = ["Senior", "Sub-23", "Juvenil", "Cadete", "Infantil"] as const;
const clubesList = [...new Set(atletas.map(a => a.club))].sort((a, b) => a.localeCompare(b, 'es'));
const provinciasList = [...new Set(atletas.map(a => a.provincia).filter((p): p is string => !!p))].sort((a, b) => a.localeCompare(b, 'es'));

const categoriaBadge: Record<string, string> = {
  "Senior":   "bg-blue-100 text-blue-800",
  "Sub-23":   "bg-purple-100 text-purple-800",
  "Juvenil":  "bg-green-100 text-green-800",
  "Cadete":   "bg-orange-100 text-orange-800",
  "Infantil": "bg-red-100 text-red-800",
};
---

<Layout title="Atletas — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-[#EFC050] text-sm font-medium mb-2">AARA</div>
      <h1 class="text-3xl md:text-4xl font-bold">Atletas afiliados</h1>
      <p class="text-gray-300 mt-2">Padrón de atletas afiliados a la Asociación Argentina de Remeros Aficionados</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12">

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      {[
        { value: atletas.length.toString(), label: "Atletas afiliados" },
        { value: new Set(atletas.map(a => a.club)).size.toString(), label: "Clubes representados" },
        { value: new Set(atletas.map(a => a.provincia)).size.toString(), label: "Provincias" },
        { value: new Set(atletas.map(a => a.categoria)).size.toString(), label: "Categorías" },
      ].map(s => (
        <div class="bg-white rounded-xl shadow p-5 text-center">
          <div class="text-3xl font-bold text-[#0B2545]">{s.value}</div>
          <div class="text-sm text-gray-500 mt-1">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow p-5 mb-6 flex flex-col gap-4">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="search"
          type="search"
          placeholder="Buscar atleta por nombre..."
          class="w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#0B2545]/30 focus:border-[#0B2545]"
        />
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <select id="filter-categoria" class="px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-[#0B2545]/30 focus:border-[#0B2545]">
          <option value="">Todas las categorías</option>
          {categorias.map(c => <option value={c}>{c}</option>)}
        </select>
        <select id="filter-genero" class="px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-[#0B2545]/30 focus:border-[#0B2545]">
          <option value="">Todos los géneros</option>
          <option value="Masculino">Masculino</option>
          <option value="Femenino">Femenino</option>
        </select>
        <select id="filter-club" class="px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-[#0B2545]/30 focus:border-[#0B2545]">
          <option value="">Todos los clubes</option>
          {clubesList.map(c => <option value={c}>{c}</option>)}
        </select>
        <select id="filter-provincia" class="px-3 py-2.5 border border-gray-200 rounded-lg text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-[#0B2545]/30 focus:border-[#0B2545]">
          <option value="">Todas las provincias</option>
          {provinciasList.map(p => <option value={p}>{p}</option>)}
        </select>
      </div>

      <div class="flex items-center justify-between">
        <p class="text-sm text-gray-500">
          Mostrando <span id="count" class="font-semibold text-[#0B2545]">{atletas.length}</span> de {atletas.length} atletas
        </p>
        <button id="clear-filters" class="text-xs text-[#13A8D4] hover:underline hidden">
          Limpiar filtros
        </button>
      </div>
    </div>

    <!-- Grid -->
    <div id="atletas-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {atletas.map(atleta => {
        const initials = atleta.nombre.split(' ').filter(Boolean).slice(0, 2).map(n => n[0].toUpperCase()).join('');
        return (
          <a
            href={`${base}/atletas/${toSlug(atleta.nombre)}`}
            class="atleta-card bg-white rounded-xl shadow hover:shadow-md hover:-translate-y-0.5 transition-all p-4 flex items-start gap-3"
            data-nombre={atleta.nombre.toLowerCase()}
            data-categoria={atleta.categoria}
            data-genero={atleta.genero}
            data-club={atleta.club}
            data-provincia={atleta.provincia}
          >
            <div class="w-10 h-10 rounded-full bg-[#0B2545] text-white flex items-center justify-center text-sm font-bold shrink-0 select-none">
              {initials}
            </div>
            <div class="min-w-0 flex-1">
              <div class="font-semibold text-[#0B2545] text-sm leading-snug truncate">{atleta.nombre}</div>
              <div class="flex flex-wrap items-center gap-1.5 mt-1">
                <span class={`text-[10px] font-semibold px-1.5 py-0.5 rounded-full ${categoriaBadge[atleta.categoria] ?? 'bg-gray-100 text-gray-700'}`}>
                  {atleta.categoria}
                </span>
                <span class="text-[10px] text-gray-400 font-medium">
                  {atleta.genero === "Masculino" ? "Masc." : "Fem."}
                </span>
              </div>
              <div class="text-xs text-gray-500 mt-1.5 truncate">{atleta.club}</div>
              <div class="flex items-center gap-0.5 mt-1">
                <svg class="w-3 h-3 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                </svg>
                <span class="text-xs text-gray-400">{atleta.provincia}</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <!-- No results -->
    <div id="no-results" class="hidden text-center py-16 text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <p class="font-medium">No se encontraron atletas</p>
      <p class="text-sm mt-1">Probá con otros filtros</p>
    </div>

    <!-- CTA -->
    <div class="mt-10 bg-[#EFC050]/10 border border-[#EFC050]/30 rounded-xl p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <p class="font-semibold text-[#0B2545]">¿Sos atleta y querés figurar en el padrón?</p>
        <p class="text-sm text-gray-600 mt-1">Contactá a tu delegado provincial o enviá tus datos a la secretaría de AARA.</p>
      </div>
      <a href={`${base}/contacto`} class="shrink-0 bg-[#0B2545] hover:bg-[#134074] text-white font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm">
        Contactar
      </a>
    </div>

  </div>
</Layout>

<script>
  const search = document.getElementById('search') as HTMLInputElement;
  const filterCategoria = document.getElementById('filter-categoria') as HTMLSelectElement;
  const filterGenero = document.getElementById('filter-genero') as HTMLSelectElement;
  const filterClub = document.getElementById('filter-club') as HTMLSelectElement;
  const filterProvincia = document.getElementById('filter-provincia') as HTMLSelectElement;
  const countEl = document.getElementById('count')!;
  const noResults = document.getElementById('no-results')!;
  const clearBtn = document.getElementById('clear-filters')!;
  const cards = document.querySelectorAll<HTMLElement>('.atleta-card');

  function applyFilters() {
    const q = search.value.toLowerCase().trim();
    const cat = filterCategoria.value;
    const gen = filterGenero.value;
    const club = filterClub.value;
    const prov = filterProvincia.value;

    let visible = 0;
    cards.forEach(card => {
      const match =
        (!q || card.dataset.nombre!.includes(q)) &&
        (!cat || card.dataset.categoria === cat) &&
        (!gen || card.dataset.genero === gen) &&
        (!club || card.dataset.club === club) &&
        (!prov || card.dataset.provincia === prov);

      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    countEl.textContent = visible.toString();
    noResults.classList.toggle('hidden', visible > 0);
    clearBtn.classList.toggle('hidden', !q && !cat && !gen && !club && !prov);
  }

  search.addEventListener('input', applyFilters);
  filterCategoria.addEventListener('change', applyFilters);
  filterGenero.addEventListener('change', applyFilters);
  filterClub.addEventListener('change', applyFilters);
  filterProvincia.addEventListener('change', applyFilters);

  clearBtn.addEventListener('click', () => {
    search.value = '';
    filterCategoria.value = '';
    filterGenero.value = '';
    filterClub.value = '';
    filterProvincia.value = '';
    applyFilters();
  });
</script>
