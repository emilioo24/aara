---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Estatuto — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-sm text-gray-400 mb-3">
        <a href={`${import.meta.env.BASE_URL}biblioteca`} class="hover:text-[#EFC050] transition-colors">Biblioteca</a>
        <span class="mx-2">/</span>
        <span class="text-white">Estatuto</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold">Estatuto</h1>
    </div>
  </div>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <div class="bg-white rounded-xl shadow p-8">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="font-bold text-[#0B2545] text-lg">Estatuto AARA</h2>
          <p class="text-sm text-gray-500 mt-1">Vigente — última modificación 2023</p>
        </div>
        <a href="#" class="flex items-center gap-2 bg-[#0B2545] hover:bg-[#134074] text-white text-sm font-medium px-4 py-2.5 rounded-lg transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
          Descargar PDF
        </a>
      </div>
      <div class="prose prose-sm max-w-none text-gray-600">
        <p class="text-gray-500 italic">El texto completo del estatuto está disponible para descarga en formato PDF.</p>
        <div class="mt-6 space-y-4">
          {["Denominación y sede", "Objeto y fines", "Del patrimonio social", "De los socios", "De las autoridades", "De las asambleas", "Del ejercicio social", "De la disolución"].map((cap, i) => (
            <div class="flex items-center gap-3 border-b border-gray-100 pb-3">
              <span class="text-xs font-bold text-[#EFC050] bg-[#0B2545] rounded-full w-6 h-6 flex items-center justify-center shrink-0">{i + 1}</span>
              <span class="font-medium text-[#0B2545]">{cap}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>
