---
import Layout from '../../layouts/Layout.astro';

const secciones = [
  { key: "calendario", title: "Calendario 2026", desc: "Fechas y sedes de todas las regatas y competencias oficiales para la temporada 2026.", href: "/biblioteca/calendario", badge: "Actualizado" },
  { key: "galeria",    title: "Galería",          desc: "Fotos y videos de competencias, eventos y actividades de AARA.",                      href: "/biblioteca/galeria",   badge: null },
  { key: "estatuto",   title: "Estatuto",          desc: "Estatuto vigente de la Asociación Argentina de Remeros Aficionados.",                 href: "/biblioteca/estatuto",  badge: null },
  { key: "reglamentos",title: "Reglamentos",       desc: "Reglamento general, de competencias, de árbitros y técnicos.",                       href: "/biblioteca/reglamentos",badge: null },
  { key: "formularios",title: "Formularios",       desc: "Formularios de inscripción, afiliación, habilitación y otros trámites.",             href: "/biblioteca/formularios",badge: null },
];
---

<Layout title="Biblioteca — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-[#EFC050] text-sm font-medium mb-2">AARA</div>
      <h1 class="text-3xl md:text-4xl font-bold">Biblioteca</h1>
      <p class="text-gray-300 mt-2">Documentos, reglamentos y recursos oficiales</p>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {secciones.map(s => (
        <a href={s.href} class="bg-white rounded-xl shadow hover:shadow-md transition-shadow p-6 flex gap-5 group">
          <div class="w-12 h-12 rounded-xl bg-[#0B2545]/8 flex items-center justify-center shrink-0 text-[#0B2545]">
            {s.key === "calendario" && (
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            )}
            {s.key === "galeria" && (
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            )}
            {s.key === "estatuto" && (
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            )}
            {s.key === "reglamentos" && (
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
            )}
            {s.key === "formularios" && (
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            )}
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <h2 class="font-bold text-[#0B2545] group-hover:text-[#134074] transition-colors">{s.title}</h2>
              {s.badge && <span class="text-xs bg-green-100 text-green-700 font-semibold px-2 py-0.5 rounded-full">{s.badge}</span>}
            </div>
            <p class="text-sm text-gray-600 leading-relaxed">{s.desc}</p>
            <div class="mt-3 text-sm text-[#13A8D4] font-medium group-hover:text-[#0B2545] transition-colors">Ver documentos →</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
