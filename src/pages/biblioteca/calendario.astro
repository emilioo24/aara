---
import Layout from '../../layouts/Layout.astro';
import { meses } from '../../data/eventos2026';

const tagStyle = {
  aara: { bg: "bg-[#EFC050]/20 text-[#7A5A00]", dot: "bg-[#EFC050]", label: "AARA" },
  int:  { bg: "bg-emerald-100 text-emerald-800", dot: "bg-emerald-500", label: "Internacional" },
  nota: { bg: "bg-blue-100 text-blue-800",       dot: "bg-blue-400",   label: "Especial" },
};

const totalEventos = meses.reduce((n, m) => n + m.eventos.length, 0);
const B = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => B + path;
---

<Layout title="Calendario 2026 — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-sm text-gray-400 mb-3">
        <a href={url('/biblioteca')} class="hover:text-[#EFC050] transition-colors">Biblioteca</a>
        <span class="mx-2">/</span>
        <span class="text-white">Calendario 2026</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold">Calendario de regatas 2026</h1>
      <p class="text-gray-300 mt-2">Actualizado al 19/12/2025 · {totalEventos} eventos</p>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 py-10">

    <!-- Top bar -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-6">
      <p class="text-sm text-gray-500">Todas las fechas son provisorias y sujetas a confirmación.</p>
      <a href="#" class="shrink-0 flex items-center gap-2 text-sm bg-[#0B2545] hover:bg-[#134074] text-white font-medium px-4 py-2 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Descargar PDF
      </a>
    </div>

    <!-- Legend -->
    <div class="flex flex-wrap items-center gap-3 mb-6 text-xs">
      <span class="text-gray-400 font-medium">Referencias:</span>
      {Object.values(tagStyle).map(t => (
        <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full font-medium ${t.bg}`}>
          <span class={`w-1.5 h-1.5 rounded-full ${t.dot}`}></span>
          {t.label}
        </span>
      ))}
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full font-medium bg-gray-100 text-gray-600">
        <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
        Club / Local
      </span>
    </div>

    <!-- Quick nav -->
    <div class="flex flex-wrap gap-1.5 mb-8">
      {meses.map(m => (
        <a href={`#${m.id}`}
          class="px-3 py-1 bg-white rounded-lg shadow-sm text-xs font-semibold text-[#0B2545] hover:bg-[#EFC050] transition-colors border border-gray-100">
          {m.nombre}
        </a>
      ))}
    </div>

    <!-- Month sections -->
    <div class="space-y-8">
      {meses.map(mes => (
        <section id={mes.id} class="scroll-mt-24">
          <div class="flex items-center gap-3 mb-3">
            <h2 class="text-base font-bold text-[#0B2545] uppercase tracking-wider">{mes.nombre}</h2>
            <div class="flex-1 h-px bg-gray-200"></div>
            <span class="text-xs text-gray-400">{mes.eventos.length} eventos</span>
          </div>

          <div class="bg-white rounded-xl shadow overflow-hidden divide-y divide-gray-50">
            {mes.eventos.map((e, i) => {
              const ts = e.tag ? tagStyle[e.tag] : null;
              const slug = `${mes.id}-ev${i + 1}`;
              const href = e.tag === 'nota' ? '' : (e.tag === 'int' && e.url ? e.url : `${B}/biblioteca/eventos/${slug}`);
              const isExternal = e.tag === 'int' && !!e.url;
              return (
                <div data-fecha={e.fecha} data-estado={e.estado ?? ''} data-href={href || undefined} data-external={isExternal ? 'true' : undefined} class={`flex items-start gap-3 px-4 py-3 ${e.tag === 'nota' ? 'bg-blue-50/50' : 'cursor-pointer hover:bg-gray-50 transition-colors'}`}>
                  <!-- Date -->
                  <div class={`w-20 shrink-0 text-center rounded-lg py-1.5 text-[#0B2545] ${e.tag === 'aara' ? 'bg-[#EFC050]/20' : e.tag === 'int' ? 'bg-emerald-50' : e.tag === 'nota' ? 'bg-blue-100' : 'bg-gray-100'}`}>
                    <div class="text-[11px] font-bold">{e.fecha}</div>
                  </div>

                  <!-- Content -->
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                      <span class={`font-semibold text-sm leading-tight ${e.tag === 'nota' ? 'text-blue-700' : 'text-[#0B2545]'}`}>
                        {e.nombre}
                      </span>
                      {ts && (
                        <span class={`inline-flex items-center gap-1 text-[10px] font-bold px-1.5 py-0.5 rounded-full ${ts.bg}`}>
                          {ts.label}
                        </span>
                      )}
                      {e.estado === 'suspendido' && (
                        <span class="text-[10px] font-semibold text-red-600 bg-red-100 px-1.5 py-0.5 rounded-full">Suspendido</span>
                      )}
                      {e.estado === 'pospuesto' && (
                        <span class="text-[10px] font-semibold text-amber-600 bg-amber-100 px-1.5 py-0.5 rounded-full">Pospuesto</span>
                      )}
                      {!e.estado && (
                        <span class="past-badge text-[10px] font-semibold text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded-full" style="display:none">Realizado</span>
                      )}
                    </div>

                    {e.tag !== 'nota' && (
                      <div class="text-xs text-gray-500 mt-0.5 flex flex-wrap items-center gap-x-2">
                        <span class="flex items-center gap-1">
                          <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                          </svg>
                          {e.sede}, {e.pais}
                        </span>
                        {e.organiza && <span class="text-gray-400">· {e.organiza}</span>}
                      </div>
                    )}

                    {e.obs && (
                      <div class={`text-xs mt-0.5 ${e.tag === 'nota' ? 'text-blue-600 font-medium' : 'text-gray-400 italic'}`}>
                        {e.obs}
                      </div>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      ))}
    </div>

    <p class="text-xs text-gray-400 mt-8 text-center">
      Calendario de Regatas 2026 · Comisión Técnica AARA · Sujeto a modificaciones
    </p>
  </div>
</Layout>

<script>
  const monthNums: Record<string, number> = {
    enero: 1, febrero: 2, marzo: 3, abril: 4, mayo: 5, junio: 6,
    julio: 7, agosto: 8, septiembre: 9, octubre: 10, noviembre: 11, diciembre: 12,
  };

  const today = new Date();
  const todayMonth = today.getMonth() + 1;
  const todayDay   = today.getDate();

  document.querySelectorAll('section[id]').forEach(section => {
    const monthNum = monthNums[section.id] || 0;
    if (!monthNum) return;

    section.querySelectorAll<HTMLElement>('[data-fecha]').forEach(row => {
      const fecha = row.dataset.fecha || '';
      let endMonth = monthNum;
      let endDay   = 1;

      if (fecha.includes('/')) {
        // e.g. "24–3/05" → ends on day 3 of month 05
        const afterDash = fecha.split('–')[1] || fecha;
        const parts = afterDash.split('/');
        endDay   = parseInt(parts[0]) || 1;
        endMonth = parseInt(parts[1]) || monthNum;
      } else if (fecha.includes('–')) {
        // e.g. "14–18" → ends on day 18
        endDay = parseInt(fecha.split('–')[1]) || 1;
      } else {
        // e.g. "6"
        endDay = parseInt(fecha) || 1;
      }

      const isPast = endMonth < todayMonth ||
        (endMonth === todayMonth && endDay < todayDay);

      if (isPast && !row.dataset.estado) {
        const badge = row.querySelector('.past-badge') as HTMLElement | null;
        if (badge) badge.style.display = 'inline-flex';
      }
    });
  });

  document.querySelectorAll<HTMLElement>('[data-href]').forEach(row => {
    const href = row.dataset.href;
    if (!href) return;
    row.addEventListener('click', () => {
      if (row.dataset.external === 'true') {
        window.open(href, '_blank', 'noopener,noreferrer');
      } else {
        window.location.href = href;
      }
    });
  });
</script>
