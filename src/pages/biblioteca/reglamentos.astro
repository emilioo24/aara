---
import Layout from '../../layouts/Layout.astro';

const reglamentos = [
  { titulo: "Reglamento General", desc: "Normas generales de la asociación y sus actividades.", fecha: "2024" },
  { titulo: "Reglamento de Competencias", desc: "Reglas y procedimientos para la organización de regatas oficiales.", fecha: "2024" },
  { titulo: "Reglamento de Árbitros", desc: "Requisitos, funciones y responsabilidades del cuerpo arbitral.", fecha: "2023" },
  { titulo: "Reglamento de Técnicos", desc: "Habilitación, categorías y obligaciones de los técnicos.", fecha: "2023" },
  { titulo: "Reglamento Antidopaje", desc: "Política de control antidopaje adoptada por AARA.", fecha: "2024" },
  { titulo: "Reglamento de Remo Costero", desc: "Normas específicas para la disciplina de remo costero.", fecha: "2024" },
];
---
<Layout title="Reglamentos — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-sm text-gray-400 mb-3">
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/biblioteca`} class="hover:text-[#EFC050] transition-colors">Biblioteca</a>
        <span class="mx-2">/</span>
        <span class="text-white">Reglamentos</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold">Reglamentos</h1>
    </div>
  </div>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {reglamentos.map(r => (
        <div class="bg-white rounded-xl shadow p-5 flex gap-4 items-start">
          <div class="w-9 h-9 rounded-lg bg-[#0B2545]/8 flex items-center justify-center text-[#0B2545] shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
            </div>
          <div class="flex-1">
            <div class="font-semibold text-[#0B2545]">{r.titulo}</div>
            <p class="text-xs text-gray-500 mt-0.5 mb-3">{r.desc}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">Ed. {r.fecha}</span>
              <a href="#" class="text-xs text-[#13A8D4] hover:text-[#0B2545] font-medium transition-colors flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                </svg>
                Descargar PDF
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
