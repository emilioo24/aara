---
import Layout from '../../layouts/Layout.astro';

const reglamentos = [
  { titulo: "Reglamento General de la A.A.R.A",                                             revision: "Aprobado el 1º de noviembre del 2012" },
  { titulo: "Reglamento General de Regatas Oficiales, Promocionales y Master",              revision: "Revisión 12/2025" },
  { titulo: "Participación de Remeros Extranjeros No Residentes",                           revision: "Aprobado el 1° de noviembre del 2014 — Acta N°1534" },
  { titulo: "Normas de Funcionamiento del Tribunal de Disciplina de la A.A.R.A.",           revision: "Revisión agosto de 2011" },
  { titulo: "Código en Referencia a la Manipulación de Competencias",                       revision: "Revisión diciembre 2023" },
  { titulo: "Jurisdicciones de las Comisiones de Regatas de la A.A.R.A",                   revision: "Junio 2018" },
  { titulo: "Reglamento Máster y Campeonato Argentino Máster",                              revision: "Enero 2025" },
  { titulo: "Reglamento de Regatas de Travesía A.A.R.A",                                   revision: "Febrero 2025" },
  { titulo: "Reglamento de Guardas de Botes y Uso del Predio y del Galpón de la A.A.R.A.", revision: "Octubre 2014" },
  { titulo: "Reglamento Comisión de Atletas",                                               revision: "Revisión 2020" },
  { titulo: "Reglamento de Administración y Funcionamiento de la Pista Nacional de Remo y Canotaje", revision: "Revisión 2015" },
  { titulo: "Reglamento Comisión de Árbitros A.A.R.A.",                                    revision: "Diciembre 2017" },
];
---
<Layout title="Reglamentos — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-sm text-gray-400 mb-3">
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/biblioteca`} class="hover:text-[#EFC050] transition-colors">Biblioteca</a>
        <span class="mx-2">/</span>
        <span class="text-white">Reglamentos</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold">Reglamentos</h1>
    </div>
  </div>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {reglamentos.map(r => (
        <div class="bg-white rounded-xl shadow p-5 flex gap-4 items-start">
          <div class="w-9 h-9 rounded-lg bg-[#0B2545]/8 flex items-center justify-center text-[#0B2545] shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
            </div>
          <div class="flex-1">
            <div class="font-semibold text-[#0B2545] leading-snug">{r.titulo}</div>
            <div class="flex items-center justify-between mt-2">
              <span class="text-xs text-gray-400">{r.revision}</span>
              <a href="#" class="text-xs text-[#13A8D4] hover:text-[#0B2545] font-medium transition-colors flex items-center gap-1 shrink-0 ml-3">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                </svg>
                Descargar PDF
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
