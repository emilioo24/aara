---
import Layout from '../../../layouts/Layout.astro';
import { todosLosEventos } from '../../../data/eventos2026';

export function getStaticPaths() {
  return todosLosEventos
    .filter(e => e.tag !== 'nota')
    .map(e => ({ params: { slug: e.slug }, props: { evento: e } }));
}

const { evento: e } = Astro.props;
const B = import.meta.env.BASE_URL.replace(/\/$/, '');

const tagStyle = {
  aara: { bg: "bg-[#EFC050]/20 text-[#7A5A00]", label: "Evento AARA" },
  int:  { bg: "bg-emerald-100 text-emerald-800", label: "Internacional" },
};

const estadoStyle = {
  suspendido: { bg: "bg-red-100 text-red-700",    label: "Suspendido" },
  pospuesto:  { bg: "bg-amber-100 text-amber-700", label: "Pospuesto"  },
};

const ts  = (e.tag === 'aara' || e.tag === 'int') ? tagStyle[e.tag] : null;
const est = e.estado ? estadoStyle[e.estado] : null;

const fechaCompleta = `${e.fecha} de ${e.mesNombre} de 2026`;
---

<Layout title={`${e.nombre} — Calendario AARA`}>
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-sm text-gray-400 mb-3 flex flex-wrap items-center gap-1">
        <a href={`${B}/biblioteca`} class="hover:text-[#EFC050] transition-colors">Biblioteca</a>
        <span class="mx-1">/</span>
        <a href={`${B}/biblioteca/calendario`} class="hover:text-[#EFC050] transition-colors">Calendario 2026</a>
        <span class="mx-1">/</span>
        <span class="text-white truncate">{e.nombre}</span>
      </nav>
      <div class="flex flex-wrap items-center gap-3 mt-1 mb-3">
        {ts  && <span class={`text-xs font-bold px-2.5 py-1 rounded-full ${ts.bg}`}>{ts.label}</span>}
        {est && <span class={`text-xs font-bold px-2.5 py-1 rounded-full ${est.bg}`}>{est.label}</span>}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold leading-tight">{e.nombre}</h1>
      <p class="text-gray-300 mt-2 text-lg">{fechaCompleta}</p>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 py-12 space-y-6">

    <!-- Info cards -->
    <div class="bg-white rounded-xl shadow p-6">
      <h2 class="text-sm font-bold text-[#0B2545] uppercase tracking-wider mb-4 flex items-center gap-2">
        <span class="w-1 h-4 bg-[#EFC050] rounded-full inline-block"></span>
        Información del evento
      </h2>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 text-sm">
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-0.5">Fecha</dt>
          <dd class="font-medium text-[#0B2545]">{fechaCompleta}</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-0.5">Sede</dt>
          <dd class="font-medium text-[#0B2545]">{e.sede}</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-0.5">País / Provincia</dt>
          <dd class="font-medium text-[#0B2545]">{e.pais}</dd>
        </div>
        {e.organiza && (
          <div>
            <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-0.5">Organiza</dt>
            <dd class="font-medium text-[#0B2545]">{e.organiza}</dd>
          </div>
        )}
        {e.obs && (
          <div class="sm:col-span-2">
            <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-0.5">Observaciones</dt>
            <dd class="text-gray-600 italic">{e.obs}</dd>
          </div>
        )}
        {e.url && (
          <div class="sm:col-span-2">
            <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-0.5">Sitio oficial</dt>
            <dd>
              <a href={e.url} target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-[#13A8D4] hover:text-[#0B2545] font-medium transition-colors">
                {e.url}
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </dd>
          </div>
        )}
      </dl>
    </div>

    <!-- Resultados -->
    <div class="bg-white rounded-xl shadow p-6">
      <h2 class="text-sm font-bold text-[#0B2545] uppercase tracking-wider mb-4 flex items-center gap-2">
        <span class="w-1 h-4 bg-[#EFC050] rounded-full inline-block"></span>
        Resultados
      </h2>
      {e.urlResultados ? (
        <a href={e.urlResultados} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#0B2545] hover:bg-[#134074] text-white text-sm font-medium px-4 py-2.5 rounded-lg transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          Ver resultados oficiales
        </a>
      ) : (
        <p class="text-sm text-gray-400 italic">Resultados aún no disponibles.</p>
      )}
    </div>

    <!-- Botes inscriptos -->
    <div class="bg-white rounded-xl shadow p-6">
      <h2 class="text-sm font-bold text-[#0B2545] uppercase tracking-wider mb-4 flex items-center gap-2">
        <span class="w-1 h-4 bg-[#EFC050] rounded-full inline-block"></span>
        Botes inscriptos
      </h2>
      {e.urlInscriptos ? (
        <a href={e.urlInscriptos} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#0B2545] hover:bg-[#134074] text-white text-sm font-medium px-4 py-2.5 rounded-lg transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          Ver botes inscriptos
        </a>
      ) : (
        <p class="text-sm text-gray-400 italic">Lista de inscriptos no disponible.</p>
      )}
    </div>

    <!-- Ranking de clubes (solo eventos club/local) -->
    {!e.tag && (
      <div class="bg-white rounded-xl shadow p-6">
        <h2 class="text-sm font-bold text-[#0B2545] uppercase tracking-wider mb-4 flex items-center gap-2">
          <span class="w-1 h-4 bg-[#EFC050] rounded-full inline-block"></span>
          Ranking de clubes
        </h2>
        {e.rankingClubes && e.rankingClubes.length > 0 ? (
          <div class="overflow-x-auto -mx-2">
            <table class="w-full text-sm">
              <thead class="text-xs font-semibold text-gray-500 uppercase tracking-wider border-b border-gray-100">
                <tr>
                  <th class="px-2 py-2 text-left w-10">#</th>
                  <th class="px-2 py-2 text-left">Club</th>
                  <th class="px-3 py-2 text-center"><span class="text-[#EFC050]">●</span></th>
                  <th class="px-3 py-2 text-center"><span class="text-gray-400">●</span></th>
                  <th class="px-3 py-2 text-center"><span class="text-amber-700">●</span></th>
                  <th class="px-2 py-2 text-right font-bold text-[#0B2545]">Pts</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                {e.rankingClubes.map(r => (
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-2 py-3">
                      {r.posicion === 1 && <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-[#EFC050] text-white text-xs font-bold">1</span>}
                      {r.posicion === 2 && <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-400 text-white text-xs font-bold">2</span>}
                      {r.posicion === 3 && <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-amber-700 text-white text-xs font-bold">3</span>}
                      {r.posicion > 3 && <span class="text-gray-400 font-medium">{r.posicion}</span>}
                    </td>
                    <td class="px-2 py-3 font-semibold text-[#0B2545]">{r.club}</td>
                    <td class="px-3 py-3 text-center text-gray-700">{r.oros}</td>
                    <td class="px-3 py-3 text-center text-gray-700">{r.platas}</td>
                    <td class="px-3 py-3 text-center text-gray-700">{r.bronces}</td>
                    <td class="px-2 py-3 text-right font-bold text-[#0B2545]">{r.puntos}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <p class="text-sm text-gray-400 italic">Ranking no disponible.</p>
        )}
      </div>
    )}

    <!-- Back -->
    <a href={`${B}/biblioteca/calendario#${e.mes}`}
      class="inline-flex items-center gap-2 text-sm text-[#13A8D4] hover:text-[#0B2545] font-medium transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Volver al calendario
    </a>

  </div>
</Layout>
