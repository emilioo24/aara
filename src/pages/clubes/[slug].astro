---
import Layout from '../../layouts/Layout.astro';
import { clubes, toSlug } from '../../data/clubes';
import { atletas, toSlug as atletaSlug } from '../../data/atletas';

export function getStaticPaths() {
  return clubes.map(club => ({
    params: { slug: toSlug(club.nombre) },
    props: { club },
  }));
}

const { club } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const iniciales = club.nombre
  .split(' ')
  .filter(Boolean)
  .slice(0, 2)
  .map((n: string) => n[0].toUpperCase())
  .join('');

const atletasDelClub = atletas.filter(a => a.club === club.nombre);
---

<Layout title={`${club.nombre} — AARA`}>
  <!-- Hero -->
  <div class="bg-gradient-to-r from-[#0B2545] to-[#134074] text-white py-12">
    <div class="max-w-4xl mx-auto px-4">
      <a
        href={`${base}/clubes`}
        class="inline-flex items-center gap-1.5 text-sm text-gray-300 hover:text-white mb-6 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Volver a clubes
      </a>

      <div class="flex items-start gap-6">
        <div class="w-20 h-20 rounded-full bg-white/10 border-2 border-white/30 flex items-center justify-center shrink-0 overflow-hidden">
          {club.escudo ? (
            <img src={base + club.escudo} alt={`Escudo ${club.nombre}`} class="w-full h-full object-contain p-1" />
          ) : (
            <span class={`font-bold text-white ${club.acronimo ? 'text-lg' : 'text-2xl'}`}>
              {club.acronimo || iniciales}
            </span>
          )}
        </div>
        <div>
          <h1 class="text-2xl md:text-3xl font-bold leading-tight">{club.nombre}</h1>
          <div class="flex items-center gap-1.5 mt-2 text-gray-300 text-sm">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            </svg>
            {club.ciudad}, {club.provincia}
          </div>
          {club.urlWeb && (
            <a
              href={club.urlWeb}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-[#EFC050] text-sm hover:underline mt-2"
            >
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              {club.urlWeb.replace(/^https?:\/\//, '')}
            </a>
          )}
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-10 flex flex-col gap-6">

    <!-- Info -->
    {(club.descripcion || club.fundacion || club.ubicacion) && (
      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Información</h2>
        {club.descripcion && (
          <p class="text-gray-700 text-sm mb-5 leading-relaxed">{club.descripcion}</p>
        )}
        <div class="space-y-3">
          {club.fundacion && (
            <div class="flex items-center gap-3 bg-gray-50 rounded-xl px-4 py-3">
              <svg class="w-4 h-4 text-[#EFC050] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <span class="text-sm text-gray-500">Fundado en</span>
              <span class="font-semibold text-[#0B2545] ml-auto">{club.fundacion}</span>
            </div>
          )}
          {club.ubicacion && (
            <div class="flex items-start gap-3 bg-gray-50 rounded-xl px-4 py-3">
              <svg class="w-4 h-4 text-[#EFC050] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              </svg>
              <span class="text-sm text-gray-500 shrink-0">Ubicación</span>
              <span class="font-medium text-[#0B2545] ml-auto text-right text-sm">{club.ubicacion}</span>
            </div>
          )}
          {club.acronimo !== undefined && (
            <div class="flex items-center gap-3 bg-gray-50 rounded-xl px-4 py-3">
              <svg class="w-4 h-4 text-[#EFC050] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
              </svg>
              <span class="text-sm text-gray-500">Acrónimo</span>
              {club.acronimo
                ? <span class="font-bold text-[#0B2545] ml-auto tracking-widest">{club.acronimo}</span>
                : <span class="text-gray-400 ml-auto text-sm italic">Sin datos</span>
              }
            </div>
          )}
        </div>
      </div>
    )}

    <!-- Colors -->
    <div class="bg-white rounded-2xl shadow p-6">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-5">Colores del club</h2>
      <div class="flex gap-8">
        <div class="text-center">
          <div
            class="w-16 h-16 rounded-2xl border border-gray-200 shadow-inner mx-auto"
            style={`background: ${club.colores.primario}`}
          ></div>
          <div class="text-xs text-gray-400 mt-2">Principal</div>
          <div class="text-xs font-mono text-gray-500 mt-0.5">{club.colores.primario}</div>
        </div>
        <div class="text-center">
          <div
            class="w-16 h-16 rounded-2xl border border-gray-200 shadow-inner mx-auto"
            style={`background: ${club.colores.secundario}`}
          ></div>
          <div class="text-xs text-gray-400 mt-2">Secundario</div>
          <div class="text-xs font-mono text-gray-500 mt-0.5">{club.colores.secundario}</div>
        </div>
      </div>
    </div>

    <!-- Oar Colors -->
    <div class="bg-white rounded-2xl shadow p-6">
      <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-5">Colores de las palas de remo</h2>
      <div class="flex items-end gap-8">
        <div class="text-center">
          <div class="mx-auto flex flex-col items-center">
            <div class="w-3 h-8 bg-gray-300 rounded-full"></div>
            <div
              class="w-12 h-20 rounded-b-full border border-gray-200 shadow-inner"
              style={`background: ${club.coloresPalas.primario}`}
            ></div>
          </div>
          <div class="text-xs text-gray-400 mt-2">Color 1</div>
          <div class="text-xs font-mono text-gray-500 mt-0.5">{club.coloresPalas.primario}</div>
        </div>
        <div class="text-center">
          <div class="mx-auto flex flex-col items-center">
            <div class="w-3 h-8 bg-gray-300 rounded-full"></div>
            <div
              class="w-12 h-20 rounded-b-full border border-gray-200 shadow-inner"
              style={`background: ${club.coloresPalas.secundario}`}
            ></div>
          </div>
          <div class="text-xs text-gray-400 mt-2">Color 2</div>
          <div class="text-xs font-mono text-gray-500 mt-0.5">{club.coloresPalas.secundario}</div>
        </div>
      </div>
    </div>

    <!-- Championships -->
    {club.campeonatos && club.campeonatos.length > 0 && (
      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Palmarés</h2>
        <ul class="space-y-2">
          {club.campeonatos.map((c: string) => (
            <li class="flex items-start gap-3 text-sm text-gray-700">
              <svg class="w-4 h-4 text-[#EFC050] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M6 2a1 1 0 000 2v1a3 3 0 006 0V4a1 1 0 100-2H6zm4 8a1 1 0 011 1v1h1a1 1 0 110 2h-1v1a1 1 0 11-2 0v-1H8a1 1 0 110-2h1v-1a1 1 0 011-1z" clip-rule="evenodd"/>
                <path d="M4 4a2 2 0 00-2 2v1a5 5 0 009.95.7A5 5 0 0018 7V6a2 2 0 00-2-2H4z"/>
              </svg>
              {c}
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Athletes -->
    {atletasDelClub.length > 0 && (
      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">
          Atletas registrados
          <span class="ml-2 bg-[#0B2545]/10 text-[#0B2545] px-2 py-0.5 rounded-full text-xs font-bold">{atletasDelClub.length}</span>
        </h2>
        <div class="space-y-1">
          {atletasDelClub.map(atleta => {
            const initials = atleta.nombre.split(' ').filter(Boolean).slice(0, 2).map((n: string) => n[0].toUpperCase()).join('');
            return (
              <a
                href={`${base}/atletas/${atletaSlug(atleta.nombre)}`}
                class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 transition-colors group"
              >
                <div class="w-9 h-9 rounded-full bg-[#0B2545]/10 flex items-center justify-center text-xs font-bold text-[#0B2545] shrink-0 overflow-hidden">
                  {atleta.avatar
                    ? <img src={atleta.avatar} alt={atleta.nombre} class="w-full h-full object-cover" />
                    : initials
                  }
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-sm font-semibold text-[#0B2545] group-hover:text-[#13A8D4] transition-colors">{atleta.nombre}</div>
                  <div class="text-xs text-gray-400">{atleta.categoria} · {atleta.genero}</div>
                </div>
                <svg class="w-4 h-4 text-gray-300 group-hover:text-[#13A8D4] transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            );
          })}
        </div>
      </div>
    )}

    {atletasDelClub.length === 0 && (
      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Atletas registrados</h2>
        <p class="text-sm text-gray-400">No hay atletas registrados en el padrón para este club.</p>
      </div>
    )}

  </div>
</Layout>
