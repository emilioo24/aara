---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-[#EFC050] text-sm font-medium mb-2">AARA</div>
      <h1 class="text-3xl md:text-4xl font-bold">Contacto</h1>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

      <!-- Left: form + seguinos -->
      <div class="space-y-6">
        <div class="bg-white rounded-xl shadow p-8">
          <h2 class="text-sm font-bold text-[#0B2545] uppercase tracking-wider mb-6 flex items-center gap-2">
            <span class="w-1 h-4 bg-[#EFC050] rounded-full inline-block"></span>
            Envianos un mensaje
          </h2>
          <form class="space-y-5">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Nombre completo</label>
              <input type="text" placeholder="Tu nombre" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#13A8D4] focus:border-transparent transition-shadow"/>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Correo electrónico</label>
              <input type="email" placeholder="tu@email.com" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#13A8D4] focus:border-transparent transition-shadow"/>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Asunto</label>
              <input type="text" placeholder="Asunto" class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#13A8D4] focus:border-transparent transition-shadow"/>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Mensaje</label>
              <textarea rows="5" placeholder="Escribí tu consulta aquí..." class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#13A8D4] focus:border-transparent transition-shadow resize-none"></textarea>
            </div>
            <button type="submit" class="w-full bg-[#0B2545] hover:bg-[#134074] text-white font-semibold py-3 rounded-lg transition-colors">
              Enviar mensaje
            </button>
          </form>
        </div>

        <div class="bg-white rounded-xl shadow p-6">
          <h3 class="font-bold text-[#0B2545] mb-4 text-sm uppercase tracking-wider flex items-center gap-2">
            <span class="w-1 h-4 bg-[#EFC050] rounded-full inline-block"></span>
            Seguinos
          </h3>
          <div class="flex gap-3">
            {[
              { label: "Facebook", href: "#" },
              { label: "Instagram", href: "#" },
              { label: "YouTube", href: "#" },
            ].map(s => (
              <a href={s.href} class="flex-1 border border-gray-200 hover:border-[#0B2545] hover:bg-[#0B2545] hover:text-white text-gray-600 rounded-lg py-2.5 text-xs font-medium text-center transition-colors">
                {s.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: info + map -->
      <div class="space-y-6">

        <div class="bg-white rounded-xl shadow p-6">
          <h3 class="font-bold text-[#0B2545] mb-4 text-sm uppercase tracking-wider flex items-center gap-2">
            <span class="w-1 h-4 bg-[#EFC050] rounded-full inline-block"></span>
            Datos de contacto
          </h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg bg-[#0B2545]/8 flex items-center justify-center text-[#0B2545] shrink-0 mt-0.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Teléfono</div>
                <div class="text-sm text-[#0B2545] font-medium mt-0.5">(011) 4152 - 5775</div>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-lg bg-[#0B2545]/8 flex items-center justify-center text-[#0B2545] shrink-0 mt-0.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</div>
                <a href="mailto:info@remoargentina.org" class="text-sm text-[#13A8D4] hover:text-[#0B2545] font-medium mt-0.5 block transition-colors">info@remoargentina.org</a>
              </div>
            </li>
          </ul>
        </div>

        <div class="bg-white rounded-xl shadow p-6">
          <h3 class="font-bold text-[#0B2545] mb-3 text-sm uppercase tracking-wider flex items-center gap-2">
            <span class="w-1 h-4 bg-[#EFC050] rounded-full inline-block"></span>
            Horarios de Administración
          </h3>
          <p class="text-sm text-gray-700">Lunes, Miércoles y Viernes de <strong>9 a 12 hs</strong></p>
        </div>

        <div class="bg-white rounded-xl shadow p-6">
          <h3 class="font-bold text-[#0B2545] mb-4 text-sm uppercase tracking-wider flex items-center gap-2">
            <span class="w-1 h-4 bg-[#EFC050] rounded-full inline-block"></span>
            Pagos por transferencia o depósitos bancarios
          </h3>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Banco</dt>
              <dd class="font-medium text-[#0B2545] mt-0.5">ICBC</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Titular</dt>
              <dd class="font-medium text-[#0B2545] mt-0.5">Asociación Argentina de Remeros Aficionados</dd>
              <dd class="text-gray-500 text-xs mt-0.5">CUIT 30-52704882-2</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Cuenta</dt>
              <dd class="font-medium text-[#0B2545] mt-0.5 font-mono">0826-0210178954</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wide">CBU</dt>
              <dd class="font-medium text-[#0B2545] mt-0.5 font-mono break-all">0150826802000101789549</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Alias</dt>
              <dd class="font-medium text-[#0B2545] mt-0.5 font-mono">AARA.TESORERIA.ADMIN</dd>
            </div>
          </dl>
        </div>

        <div class="bg-white rounded-xl shadow overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100">
            <h3 class="font-bold text-[#0B2545] text-sm uppercase tracking-wider flex items-center gap-2">
              <span class="w-1 h-4 bg-[#EFC050] rounded-full inline-block"></span>
              Ubicación
            </h3>
            <p class="text-xs text-gray-500 mt-1">Pista Nacional de Remo — Tigre, Buenos Aires</p>
          </div>
          <div class="aspect-video">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3291.178444176405!2d-58.616633099999994!3d-34.4222222!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bca448a10df095%3A0x9d20d7052787b2f6!2sPista%20Nacional%20de%20Remo!5e0!3m2!1ses!2sar!4v1778360859654!5m2!1ses!2sar"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>
