---

<Layout title="Delegados — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-[#EFC050] text-sm font-medium mb-2">AARA</div>
      <h1 class="text-3xl md:text-4xl font-bold">Delegados</h1>
      <p class="text-gray-300 mt-2">Representantes de cada club afiliado ante la Asociación</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12 space-y-14">

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        { value: categoriaA.length.toString(), label: "Clubes categoría A" },
        { value: totalA.toString(),            label: "Delegados cat. A" },
        { value: categoriaB.length.toString(), label: "Clubes categoría B" },
        { value: totalB.toString(),            label: "Delegados cat. B" },
      ].map(s => (
        <div class="bg-white rounded-xl shadow p-5 text-center">
          <div class="text-3xl font-bold text-[#0B2545]">{s.value}</div>
          <div class="text-sm text-gray-500 mt-1">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Categoría A -->
    <section>
      <h2 class="text-xl font-bold text-[#0B2545] mb-6 flex items-center gap-2">
        <span class="w-1 h-6 bg-[#EFC050] rounded-full inline-block"></span>
        Clubes categoría A
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {categoriaA.map(c => (
          <div class="bg-white rounded-xl shadow overflow-hidden">
            <div class="bg-[#0B2545] px-4 py-3">
              <span class="text-white font-semibold text-sm leading-snug">{c.club}</span>
            </div>
            <ul class="px-4 py-3 space-y-1.5">
              {c.delegados.map((d, i) => (
                <li class="flex items-center gap-2 text-sm text-gray-700">
                  <span class="w-5 h-5 rounded-full bg-[#0B2545]/10 text-[#0B2545] text-[10px] font-bold flex items-center justify-center shrink-0">
                    {i + 1}
                  </span>
                  {d}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Categoría B -->
    <section>
      <h2 class="text-xl font-bold text-[#0B2545] mb-6 flex items-center gap-2">
        <span class="w-1 h-6 bg-[#EFC050] rounded-full inline-block"></span>
        Clubes categoría B
      </h2>
      <div class="bg-white rounded-xl shadow overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[#0B2545] text-white text-left">
              <th class="px-5 py-3.5 font-semibold">Club</th>
              <th class="px-5 py-3.5 font-semibold">Delegado</th>
            </tr>
          </thead>
          <tbody>
            {categoriaB.map((c, i) => (
              <tr class={i % 2 === 0 ? "bg-gray-50" : "bg-white"}>
                <td class="px-5 py-3 font-medium text-[#0B2545]">{c.club}</td>
                <td class="px-5 py-3">
                  {c.delegados.length > 0
                    ? <span class="text-gray-700">{c.delegados[0]}</span>
                    : <span class="text-gray-400 italic">No designó</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- CTA -->
    <div class="bg-[#EFC050]/10 border border-[#EFC050]/30 rounded-xl p-6">
      <p class="text-sm text-gray-700">
        <strong>¿Tu club aún no designó delegado?</strong> Comunicate con la secretaría de AARA para registrar al representante de tu institución. <a href={url('/contacto')} class="text-[#13A8D4] hover:underline">Contactanos</a>.
      </p>
    </div>

  </div>
</Layout>
