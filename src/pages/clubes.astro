---

<Layout title="Clubes — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-[#EFC050] text-sm font-medium mb-2">AARA</div>
      <h1 class="text-3xl md:text-4xl font-bold">Clubes afiliados</h1>
      <p class="text-gray-300 mt-2">Clubes que integran la Asociación Argentina de Remeros Aficionados</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      {[
        { value: clubes.length.toString(), label: "Clubes afiliados" },
        { value: provincias.length.toString(), label: "Provincias" },
        { value: "+500", label: "Atletas activos" },
        { value: "+80", label: "Árbitros" },
      ].map(s => (
        <div class="bg-white rounded-xl shadow p-5 text-center">
          <div class="text-3xl font-bold text-[#0B2545]">{s.value}</div>
          <div class="text-sm text-gray-500 mt-1">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Filter hint -->
    <div class="flex items-center gap-3 mb-6">
      <h2 class="text-xl font-bold text-[#0B2545]">Listado de clubes</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {clubes.map(club => (
        <div class="bg-white rounded-xl shadow hover:shadow-md transition-shadow p-5 flex items-start gap-4">
          <div class="w-10 h-10 bg-[#0B2545]/10 rounded-full flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-[#0B2545]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <div>
            <div class="font-semibold text-[#0B2545] leading-snug">{club.nombre}</div>
            <div class="text-xs text-gray-500 mt-1 flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              </svg>
              {club.ciudad}, {club.provincia}
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="text-sm text-gray-400 mt-8 text-center">
      ¿Tu club no figura? <a href={`${import.meta.env.BASE_URL}contacto`} class="text-[#13A8D4] hover:underline">Contactanos</a> para gestionar la afiliación.
    </p>
  </div>
</Layout>
