---
import Layout from '../layouts/Layout.astro';
import { clubes, toSlug } from '../data/clubes';

const provincias = [...new Set(clubes.map(c => c.provincia))].sort();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Clubes — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-[#EFC050] text-sm font-medium mb-2">AARA</div>
      <h1 class="text-3xl md:text-4xl font-bold">Clubes afiliados</h1>
      <p class="text-gray-300 mt-2">Clubes que integran la Asociación Argentina de Remeros Aficionados</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      {[
        { value: clubes.length.toString(), label: "Clubes afiliados" },
        { value: provincias.length.toString(), label: "Provincias" },
        { value: "+500", label: "Atletas activos" },
        { value: "+80", label: "Árbitros" },
      ].map(s => (
        <div class="bg-white rounded-xl shadow p-5 text-center">
          <div class="text-3xl font-bold text-[#0B2545]">{s.value}</div>
          <div class="text-sm text-gray-500 mt-1">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Search + Filter -->
    <div class="flex flex-col sm:flex-row gap-3 mb-4">
      <div class="relative flex-1">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          id="search"
          type="text"
          placeholder="Buscar club..."
          class="w-full pl-9 pr-4 py-2.5 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:border-[#0B2545] focus:ring-1 focus:ring-[#0B2545]/20"
        />
      </div>
      <select
        id="filtro-provincia"
        class="border border-gray-200 rounded-lg px-3 py-2.5 text-sm bg-white focus:outline-none focus:border-[#0B2545] focus:ring-1 focus:ring-[#0B2545]/20 min-w-[180px]"
      >
        <option value="">Todas las provincias</option>
        {provincias.map(p => <option value={p}>{p}</option>)}
      </select>
    </div>

    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-[#0B2545]">Listado de clubes</h2>
      <p class="text-sm text-gray-400">
        <span id="count">{clubes.length}</span> de {clubes.length} clubes
      </p>
    </div>

    <!-- Empty state -->
    <p id="empty" class="hidden text-center text-gray-400 py-16 text-sm">
      No se encontraron clubes con ese criterio.
    </p>

    <div id="grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {clubes.map(club => (
        <a
          href={`${base}/clubes/${toSlug(club.nombre)}`}
          data-nombre={club.nombre.toLowerCase()}
          data-provincia={club.provincia}
          data-card
          class="group bg-white rounded-xl shadow hover:shadow-md transition-all p-5 flex items-start gap-4"
        >
          <div class="w-10 h-10 rounded-full shrink-0 flex items-center justify-center border-2"
            style={`background-color: ${club.colores.primario}22; border-color: ${club.colores.primario}55`}>
            <svg class="w-5 h-5" style={`color: ${club.colores.primario}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-[#0B2545] leading-snug group-hover:text-[#13A8D4] transition-colors">
              {club.nombre}
            </div>
            <div class="text-xs text-gray-500 mt-1 flex items-center gap-1">
              <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              </svg>
              {club.ciudad}, {club.provincia}
            </div>
            <div class="flex items-center gap-1.5 mt-2">
              <span class="w-3.5 h-3.5 rounded-full border border-white/50 shadow-sm" style={`background: ${club.colores.primario}`}></span>
              <span class="w-3.5 h-3.5 rounded-full border border-gray-200 shadow-sm" style={`background: ${club.colores.secundario}`}></span>
            </div>
          </div>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-[#13A8D4] transition-colors shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>

    <p class="text-sm text-gray-400 mt-8 text-center">
      ¿Tu club no figura? <a href={`${base}/contacto`} class="text-[#13A8D4] hover:underline">Contactanos</a> para gestionar la afiliación.
    </p>
  </div>
</Layout>

<script>
  const search = document.getElementById('search') as HTMLInputElement;
  const select = document.getElementById('filtro-provincia') as HTMLSelectElement;
  const countEl = document.getElementById('count')!;
  const emptyEl = document.getElementById('empty')!;
  const cards = document.querySelectorAll<HTMLElement>('[data-card]');
  const total = cards.length;

  function filter() {
    const q = search.value.toLowerCase().trim();
    const prov = select.value;
    let visible = 0;

    cards.forEach(card => {
      const matchNombre = !q || card.dataset.nombre!.includes(q);
      const matchProv = !prov || card.dataset.provincia === prov;
      const show = matchNombre && matchProv;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    countEl.textContent = String(visible);
    emptyEl.classList.toggle('hidden', visible > 0);
  }

  search.addEventListener('input', filter);
  select.addEventListener('change', filter);
</script>
