---
import Layout from '../layouts/Layout.astro';

const B = import.meta.env.BASE_URL.replace(/\/$/, '');

type ClubRanking = {
  posicion: number;
  club: string;
  provincia: string;
  puntos: number;
  oros: number;
  platas: number;
  bronces: number;
};

const temporada = "2026";

const ranking: ClubRanking[] = [
  { posicion: 1,  club: "Club de Remo Corrientes",      provincia: "Corrientes",   puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 2,  club: "Regatas y Pelota Vasca",        provincia: "Corrientes",   puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 3,  club: "Club Náutico Hacoaj",           provincia: "Buenos Aires", puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 4,  club: "Club de Regatas La Marina",     provincia: "Santa Fe",     puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 5,  club: "Club Regatas Resistencia",      provincia: "Chaco",        puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 6,  club: "Rowing Club Argentino",         provincia: "Buenos Aires", puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 7,  club: "Club Atlético San Isidro",      provincia: "Buenos Aires", puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 8,  club: "Club Náutico Concordia",        provincia: "Entre Ríos",   puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 9,  club: "Club de Regatas Rosario",       provincia: "Santa Fe",     puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 10, club: "Club Náutico Zárate",           provincia: "Buenos Aires", puntos: 0, oros: 0, platas: 0, bronces: 0 },
];

---

<Layout title="Ranking de Clubes — AARA">
  <div class="bg-[#0B2545] text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-sm text-gray-400 mb-3 flex flex-wrap items-center gap-1">
        <a href={`${B}/resultados`} class="hover:text-[#EFC050] transition-colors">Resultados</a>
        <span class="mx-1">/</span>
        <span class="text-white">Ranking de clubes</span>
      </nav>
      <div class="text-[#EFC050] text-sm font-medium mb-2">AARA</div>
      <h1 class="text-3xl md:text-4xl font-bold">Ranking de clubes</h1>
      <p class="text-gray-300 mt-2">Temporada {temporada} · Actualizado según resultados oficiales</p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-12">

    <div class="bg-white rounded-xl shadow overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-bold text-[#0B2545] text-sm uppercase tracking-wider">Temporada {temporada}</h2>
        <span class="text-xs text-gray-400">Puntuación acumulada</span>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-xs font-semibold text-gray-500 uppercase tracking-wider">
            <tr>
              <th class="px-6 py-3 text-left w-12">#</th>
              <th class="px-6 py-3 text-left">Club</th>
              <th class="px-4 py-3 text-left hidden sm:table-cell">Provincia</th>
              <th class="px-4 py-3 text-center">
                <span class="text-[#EFC050]">●</span>
              </th>
              <th class="px-4 py-3 text-center">
                <span class="text-gray-400">●</span>
              </th>
              <th class="px-4 py-3 text-center">
                <span class="text-amber-700">●</span>
              </th>
              <th class="px-6 py-3 text-right font-bold text-[#0B2545]">Pts</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            {ranking.map(r => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4">
                  {r.posicion === 1 && (
                    <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-[#EFC050] text-white text-xs font-bold shadow-sm">1</span>
                  )}
                  {r.posicion === 2 && (
                    <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-gray-400 text-white text-xs font-bold shadow-sm">2</span>
                  )}
                  {r.posicion === 3 && (
                    <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-amber-700 text-white text-xs font-bold shadow-sm">3</span>
                  )}
                  {r.posicion > 3 && (
                    <span class="text-gray-400 font-medium text-sm">{r.posicion}</span>
                  )}
                </td>
                <td class="px-6 py-4 font-semibold text-[#0B2545]">{r.club}</td>
                <td class="px-4 py-4 text-gray-500 hidden sm:table-cell">{r.provincia}</td>
                <td class="px-4 py-4 text-center text-gray-700">{r.oros}</td>
                <td class="px-4 py-4 text-center text-gray-700">{r.platas}</td>
                <td class="px-4 py-4 text-center text-gray-700">{r.bronces}</td>
                <td class="px-6 py-4 text-right font-bold text-[#0B2545]">{r.puntos}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="px-6 py-4 bg-gray-50 border-t border-gray-100">
        <p class="text-xs text-gray-400">
          El ranking se actualiza tras cada regata oficial del calendario AARA.
          Los puntos se asignan según el sistema de puntuación aprobado por la Comisión Técnica.
        </p>
      </div>
    </div>

    <div class="mt-6 flex flex-wrap gap-4">
      <a href={`${B}/resultados`}
        class="inline-flex items-center gap-2 text-sm text-[#13A8D4] hover:text-[#0B2545] font-medium transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Volver a resultados
      </a>
    </div>

  </div>
</Layout>
