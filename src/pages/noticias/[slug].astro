---
import Layout from '../../layouts/Layout.astro';
import { noticias, colorMap } from '../../data/noticias';

export function getStaticPaths() {
  return noticias.map(n => ({ params: { slug: n.slug }, props: { noticia: n } }));
}

const { noticia } = Astro.props;
const otras = noticias.filter(n => n.slug !== noticia.slug).slice(0, 3);
const B = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={`${noticia.titulo} — AARA`}>
  <!-- Hero -->
  <div class="bg-gradient-to-r from-[#0B2545] to-[#134074] text-white py-14">
    <div class="max-w-4xl mx-auto px-4">
      <a href={B + '/noticias'} class="inline-flex items-center gap-1.5 text-sm text-white/60 hover:text-white transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Todas las noticias
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${colorMap[noticia.categoria] ?? "bg-gray-100 text-gray-600"}`}>
          {noticia.categoria}
        </span>
        <span class="text-white/50 text-sm">{noticia.fecha}</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold leading-tight">{noticia.titulo}</h1>
      <p class="text-gray-300 mt-4 text-lg leading-relaxed max-w-2xl">{noticia.resumen}</p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Article body -->
      <article class="lg:col-span-2 bg-white rounded-xl shadow p-8 prose prose-lg prose-headings:text-[#0B2545] prose-headings:font-bold prose-h2:text-xl prose-h2:mt-8 prose-h2:mb-3 prose-p:text-gray-700 prose-p:leading-relaxed prose-li:text-gray-700 prose-a:text-[#13A8D4] prose-a:no-underline hover:prose-a:underline max-w-none" set:html={noticia.contenido} />

      <!-- Sidebar -->
      <aside class="space-y-5">
        <div class="bg-white rounded-xl shadow p-6">
          <h3 class="font-bold text-[#0B2545] mb-4 text-sm uppercase tracking-wide">Otras noticias</h3>
          <ul class="space-y-4">
            {otras.map(o => (
              <li>
                <a href={`${B}/noticias/${o.slug}`} class="group block">
                  <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${colorMap[o.categoria] ?? "bg-gray-100 text-gray-600"}`}>
                    {o.categoria}
                  </span>
                  <p class="text-sm font-semibold text-[#0B2545] mt-1.5 leading-snug group-hover:text-[#134074] transition-colors">
                    {o.titulo}
                  </p>
                  <p class="text-xs text-gray-400 mt-0.5">{o.fecha}</p>
                </a>
              </li>
            ))}
          </ul>
          <a href={B + '/noticias'} class="mt-5 flex items-center gap-1 text-sm text-[#13A8D4] font-medium hover:text-[#0B2545] transition-colors">
            Ver todas <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="bg-[#0B2545] text-white rounded-xl p-6">
          <h3 class="font-bold mb-2 text-sm">¿Tenés consultas?</h3>
          <p class="text-gray-300 text-sm leading-relaxed mb-4">
            Contactá a la administración de AARA por teléfono, correo o visitanos en Tigre.
          </p>
          <a href={B + '/contacto'} class="inline-flex items-center gap-1.5 text-sm bg-[#EFC050] text-[#0B2545] font-semibold px-4 py-2 rounded-lg hover:bg-[#d4a017] transition-colors">
            Ir a Contacto
          </a>
        </div>
      </aside>

    </div>
  </div>
</Layout>
