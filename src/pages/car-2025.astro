---
import Layout from '../layouts/Layout.astro';
import ResultTable from '../components/ResultTable.astro';
import rawDataJson from '../data/car2025_full.json';

type Resultado = { pos: number; club: string; atletas: string; tiempo: string };
type Fase      = { label: string; esFinal: boolean; resultados: Resultado[] };
type Prueba    = { nombre: string; tipo: string; cat: string; gen: string; fases: Fase[] };

const todas = Object.values(rawDataJson) as unknown as Prueba[];

const tipoOrder = ['Single','Dos Sin','Doble par','Cuatro Sin','Cuádruple par','Ocho'];
const catOrder  = ['Menor','Sub 23 PL','Sub 23','PL','Junior','Intermedia','Senior','Adaptados'];
const genOrder  = ['F','M','X'];

const grupos = tipoOrder.map(tipo => {
  const pruebas = todas
    .filter(p => p.tipo === tipo)
    .sort((a, b) => {
      const gi = genOrder.indexOf(a.gen) - genOrder.indexOf(b.gen);
      return gi !== 0 ? gi : catOrder.indexOf(a.cat) - catOrder.indexOf(b.cat);
    });
  return { titulo: tipo, pruebas };
}).filter(g => g.pruebas.length > 0);

// Medals from best race (Final if exists, else first race)
const medallasMap = new Map<string, { oros: number; platas: number; bronces: number }>();
for (const p of todas) {
  const best = p.fases.find(f => f.esFinal) ?? p.fases[0];
  for (const r of best?.resultados ?? []) {
    if (r.pos > 3) continue;
    if (!medallasMap.has(r.club)) medallasMap.set(r.club, { oros: 0, platas: 0, bronces: 0 });
    const m = medallasMap.get(r.club)!;
    if (r.pos === 1) m.oros++;
    else if (r.pos === 2) m.platas++;
    else m.bronces++;
  }
}
const rankingClubes = [...medallasMap.entries()]
  .map(([club, m]) => ({ club, ...m }))
  .sort((a, b) => b.oros - a.oros || b.platas - a.platas || b.bronces - a.bronces)
  .map((r, i) => ({ posicion: i + 1, ...r }));

const programa = [
  { dia: 'Miér', fecha: '29 Oct', actividad: 'Series clasificatorias — todas las categorías' },
  { dia: 'Jue',  fecha: '30 Oct', actividad: 'Series clasificatorias y Semifinales' },
  { dia: 'Vie',  fecha: '31 Oct', actividad: 'Primeras finales — 8 pruebas' },
  { dia: 'Sáb',  fecha: '1 Nov',  actividad: 'Finales — Menor Masculino y Sub 23' },
  { dia: 'Dom',  fecha: '2 Nov',  actividad: 'Finales — Junior, Sub 23 PL, Menor Fem., Intermedia Masc.' },
];

const boatCapacity: Record<string, number> = {
  'Single': 1, 'Dos Sin': 2, 'Doble par': 2,
  'Cuatro Sin': 4, 'Cuádruple par': 4, 'Ocho': 9,
};

const genLabel: Record<string, string> = { F: 'Femenino', M: 'Masculino', X: 'Mixto' };
const catLabel: Record<string, string> = { 'PL': 'Peso Ligero', 'Sub 23 PL': 'Sub 23 Peso Ligero' };

function displayLabel(label: string, isOnly: boolean) {
  if (isOnly && label.startsWith('Eliminatoria')) return 'Final directa';
  return label;
}

function phaseStyle(label: string) {
  if (label === 'Final A' || label === 'Final directa') return 'bg-[#EFC050] text-[#0B2545] font-bold';
  if (label.startsWith('Final'))                        return 'bg-amber-100 text-amber-700 font-semibold';
  if (label.startsWith('Semifinal'))                  return 'bg-blue-100 text-blue-700 font-semibold';
  return 'bg-gray-100 text-gray-500';
}
---

<Layout title="CAR 2025 — Campeonato Argentino de Remo">
  <!-- Hero -->
  <div class="bg-gradient-to-r from-[#0B2545] to-[#134074] text-white py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-[#EFC050] text-sm font-semibold uppercase tracking-widest mb-3">Campeonato Argentino de Remo</div>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">CAR 2025</h1>
      <p class="text-gray-300 text-lg mb-6">Tigre, Buenos Aires — 29 de octubre al 2 de noviembre 2025</p>
      <div class="flex flex-wrap gap-4">
        <div class="bg-white/10 rounded-lg px-4 py-3 text-center">
          <div class="text-2xl font-bold text-[#EFC050]">5</div>
          <div class="text-xs text-gray-300 mt-0.5">Días de competencia</div>
        </div>
        <div class="bg-white/10 rounded-lg px-4 py-3 text-center">
          <div class="text-2xl font-bold text-[#EFC050]">{todas.length}</div>
          <div class="text-xs text-gray-300 mt-0.5">Pruebas disputadas</div>
        </div>
        <div class="bg-white/10 rounded-lg px-4 py-3 text-center">
          <div class="text-2xl font-bold text-[#EFC050]">+30</div>
          <div class="text-xs text-gray-300 mt-0.5">Clubes participantes</div>
        </div>
        <div class="bg-white/10 rounded-lg px-4 py-3 text-center">
          <div class="text-2xl font-bold text-[#EFC050]">2000m</div>
          <div class="text-xs text-gray-300 mt-0.5">Distancia oficial</div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      <div class="lg:col-span-2 space-y-8">

        <!-- Programa -->
        <details class="group/programa bg-white rounded-xl shadow overflow-hidden">
          <summary class="flex items-center justify-between px-8 py-5 cursor-pointer list-none hover:bg-gray-50 transition-colors">
            <h2 class="text-xl font-bold text-[#0B2545]">Programa de competencia</h2>
            <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open/programa:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="px-8 pb-8 pt-2 space-y-4">
            {programa.map(p => (
              <div class="flex gap-5 items-start">
                <div class="w-24 shrink-0 text-center bg-[#0B2545] text-white rounded-lg py-2 px-3">
                  <div class="text-xs text-[#EFC050]">{p.dia}</div>
                  <div class="text-sm font-bold mt-0.5">{p.fecha}</div>
                </div>
                <div class="pt-1">
                  <p class="font-medium text-[#0B2545]">{p.actividad}</p>
                </div>
              </div>
            ))}
          </div>
        </details>

        <!-- Resultados -->
        <section class="space-y-4">
          <div>
            <h2 class="text-xl font-bold text-[#0B2545]">Resultados por prueba</h2>
            <p class="text-sm text-gray-500 mt-1">Todas las series, semifinales y finales. Desplegá cada sección para ver los resultados.</p>
          </div>

          {grupos.map(grupo => {
            const gens = genOrder.filter(g => grupo.pruebas.some(p => p.gen === g));
            return (
              <details class="group/grupo bg-white rounded-xl shadow overflow-hidden">
                <summary class="flex items-center justify-between bg-[#0B2545] px-6 py-4 cursor-pointer list-none hover:bg-[#134074] transition-colors">
                  <h3 class="text-white font-bold text-lg">{grupo.titulo}</h3>
                  <div class="flex items-center gap-3">
                    <span class="text-xs text-white/60">{grupo.pruebas.length} pruebas</span>
                    <svg class="w-5 h-5 text-white/70 shrink-0 transition-transform group-open/grupo:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </div>
                </summary>

                <div class="divide-y divide-gray-100">
                  {gens.map(gen => {
                    const pruebas = grupo.pruebas.filter(p => p.gen === gen);
                    return (
                      <details class="group/gen border-b border-gray-100 last:border-0">
                        <summary class="flex items-center justify-between px-6 py-3 bg-gray-50 cursor-pointer list-none hover:bg-gray-100 transition-colors">
                          <span class="text-xs font-bold uppercase tracking-wider text-gray-500">{genLabel[gen]}</span>
                          <div class="flex items-center gap-2">
                            <span class="text-xs text-gray-400">{pruebas.length} {pruebas.length === 1 ? 'prueba' : 'pruebas'}</span>
                            <svg class="w-3.5 h-3.5 text-gray-400 shrink-0 transition-transform group-open/gen:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                          </div>
                        </summary>

                        {pruebas.map(prueba => {
                          const bestFase = prueba.fases.find(f => f.esFinal) ?? prueba.fases[0];
                          const winner = bestFase?.resultados[0];
                          const hasMultiple = prueba.fases.length > 1;
                          return (
                            <details class="group/prueba border-b border-gray-100 last:border-0">
                              <summary class="flex items-center gap-3 px-6 py-4 cursor-pointer hover:bg-blue-50 transition-colors list-none">
                                <svg class="w-4 h-4 text-gray-400 shrink-0 transition-transform group-open/prueba:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                </svg>
                                <div class="flex-1 min-w-0">
                                  <div class="flex items-center gap-2 flex-wrap">
                                    <span class="font-semibold text-[#0B2545] text-sm">{catLabel[prueba.cat] ?? prueba.cat}</span>
                                  </div>
                                  {winner && (
                                    <div class="text-xs text-gray-500 mt-0.5 truncate">
                                      <span style="background:#EFC050" class="inline-flex items-center justify-center w-4 h-4 rounded-full text-white text-[9px] font-bold mr-1">1</span>{winner.club} &mdash; {winner.tiempo}
                                    </div>
                                  )}
                                </div>
                                <span class="text-xs text-gray-400 shrink-0">
                                  {prueba.fases.length} {prueba.fases.length === 1 ? 'carrera' : 'carreras'}
                                </span>
                              </summary>

                              <div class="px-6 pb-5 pt-2 space-y-3">
                                {hasMultiple ? (
                                  prueba.fases.map(fase => (
                                    <details class="group/fase rounded-lg border border-gray-200 overflow-hidden">
                                      <summary class="flex items-center justify-between px-4 py-2.5 cursor-pointer hover:bg-gray-50 transition-colors list-none bg-white">
                                        <span class={`text-xs px-2.5 py-1 rounded-full ${phaseStyle(fase.label)}`}>
                                          {fase.label}
                                        </span>
                                        <div class="flex items-center gap-3">
                                          <span class="text-xs text-gray-400">{fase.resultados.length} botes</span>
                                          <svg class="w-3.5 h-3.5 text-gray-400 shrink-0 transition-transform group-open/fase:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                          </svg>
                                        </div>
                                      </summary>
                                      <div class="border-t border-gray-100">
                                        <ResultTable results={fase.resultados} capacity={boatCapacity[prueba.tipo]} />
                                      </div>
                                    </details>
                                  ))
                                ) : (
                                  <div>
                                    <span class={`inline-block text-xs px-2.5 py-1 rounded-full mb-3 ${phaseStyle(displayLabel(prueba.fases[0].label, true))}`}>
                                      {displayLabel(prueba.fases[0].label, true)}
                                    </span>
                                    <ResultTable results={prueba.fases[0].resultados} capacity={boatCapacity[prueba.tipo]} />
                                  </div>
                                )}
                              </div>
                            </details>
                          );
                        })}
                      </details>
                    );
                  })}
                </div>
              </details>
            );
          })}
        </section>

        <!-- Medallas de cada club -->
        <details class="group/medallas bg-white rounded-xl shadow overflow-hidden">
          <summary class="flex items-center justify-between px-8 py-5 border-b border-gray-100 cursor-pointer list-none hover:bg-gray-50 transition-colors">
            <h2 class="text-xl font-bold text-[#0B2545]">Medallas de cada club</h2>
            <div class="flex items-center gap-3">
              <span class="text-xs text-gray-400">Finales · {rankingClubes.length} clubes</span>
              <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform group-open/medallas:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </summary>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 text-xs font-semibold text-gray-500 uppercase tracking-wider">
                <tr>
                  <th class="px-6 py-3 text-left w-12">#</th>
                  <th class="px-6 py-3 text-left">Club</th>
                  <th class="px-4 py-3 text-center text-yellow-500">Oro</th>
                  <th class="px-4 py-3 text-center text-gray-400">Plata</th>
                  <th class="px-4 py-3 text-center text-amber-700">Bronce</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                {rankingClubes.map(r => (
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4">
                      {r.posicion === 1 && <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-white text-xs font-bold shadow-sm" style="background:#EFC050">1</span>}
                      {r.posicion === 2 && <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-gray-400 text-white text-xs font-bold shadow-sm">2</span>}
                      {r.posicion === 3 && <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-amber-700 text-white text-xs font-bold shadow-sm">3</span>}
                      {r.posicion > 3 && <span class="text-gray-400 text-sm pl-2">{r.posicion}</span>}
                    </td>
                    <td class="px-6 py-4 font-semibold text-[#0B2545]">{r.club}</td>
                    <td class="px-4 py-4 text-center font-bold text-yellow-500">{r.oros || '—'}</td>
                    <td class="px-4 py-4 text-center font-bold text-gray-400">{r.platas || '—'}</td>
                    <td class="px-4 py-4 text-center font-bold text-amber-700">{r.bronces || '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="px-8 py-4 bg-gray-50 border-t border-gray-100">
            <p class="text-xs text-gray-400">Contabiliza la carrera definitiva por prueba (Final si hubo, Serie única si no).</p>
          </div>
        </details>

      </div>

      <!-- Sidebar -->
      <div class="space-y-4">
        <div class="bg-white rounded-xl shadow p-6">
          <h3 class="font-bold text-[#0B2545] mb-4">Documentos CAR 2025</h3>
          <ul class="space-y-3">
            {[
              { label: "Resultados oficiales completos", href: "http://resultados.remoargentina.org/#/results/393" },
              { label: "Reglamento de competencia",      href: "/biblioteca/reglamentos" },
              { label: "Formulario de inscripción",      href: "/biblioteca/formularios" },
            ].map(d => (
              <li>
                <a href={d.href} target="_blank" rel="noopener" class="flex items-center gap-2 text-sm text-[#134074] hover:text-[#0B2545] transition-colors font-medium">
                  <svg class="w-4 h-4 text-[#EFC050] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  {d.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-[#0B2545] text-white rounded-xl p-6">
          <h3 class="font-bold mb-2">Sede</h3>
          <p class="text-gray-300 text-sm leading-relaxed">
            Pista Nacional de Remo<br/>
            Tigre, Buenos Aires
          </p>
        </div>

        <div class="bg-white rounded-xl shadow p-6">
          <h3 class="font-bold text-[#0B2545] mb-4">Campeones destacados</h3>
          <div class="space-y-3 text-sm">
            <div class="border-l-4 border-yellow-400 pl-3">
              <div class="font-semibold text-[#0B2545]">Menin, Santino</div>
              <div class="text-xs text-gray-500">Club Náutico Hacoaj · 2 oros en finales (Single Sub 23 y Sub 23 PL Masculino)</div>
            </div>
            <div class="border-l-4 border-yellow-400 pl-3">
              <div class="font-semibold text-[#0B2545]">Club Canottieri Italiani</div>
              <div class="text-xs text-gray-500">Mayor cosecha: 3 oros en finales (Single Junior Fem., Single Menor Masc., Doble par Junior Masc.)</div>
            </div>
            <div class="border-l-4 border-yellow-400 pl-3">
              <div class="font-semibold text-[#0B2545]">Bazan, Ignacio</div>
              <div class="text-xs text-gray-500">Campana Boat Club · Oro Single Junior Masculino — 06:46.27</div>
            </div>
            <div class="border-l-4 border-yellow-400 pl-3">
              <div class="font-semibold text-[#0B2545]">Dickson, Pedro</div>
              <div class="text-xs text-gray-500">Buenos Aires Rowing Club · Oro Single Peso Ligero Masculino — 07:15.29</div>
            </div>
            <div class="border-l-4 border-yellow-400 pl-3">
              <div class="font-semibold text-[#0B2545]">Prados, Felicitas</div>
              <div class="text-xs text-gray-500">Club Canottieri Italiani · Oro Single Junior Femenino — 08:22.41</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
