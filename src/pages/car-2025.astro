---
import Layout from '../layouts/Layout.astro';

type ClubRanking = {
  posicion: number;
  club: string;
  puntos: number;
  oros: number;
  platas: number;
  bronces: number;
};

const rankingClubes: ClubRanking[] = [
  { posicion: 1,  club: "Club de Remo Corrientes",      puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 2,  club: "Regatas y Pelota Vasca",        puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 3,  club: "Club Náutico Hacoaj",           puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 4,  club: "Club de Regatas La Marina",     puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 5,  club: "Club Regatas Resistencia",      puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 6,  club: "Rowing Club Argentino",         puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 7,  club: "Club Atlético San Isidro",      puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 8,  club: "Club Náutico Concordia",        puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 9,  club: "Club de Regatas Rosario",       puntos: 0, oros: 0, platas: 0, bronces: 0 },
  { posicion: 10, club: "Club Náutico Zárate",           puntos: 0, oros: 0, platas: 0, bronces: 0 },
];

const programa = [
  { dia: "Viernes", fecha: "21 Nov 2025", actividad: "Acreditaciones y entrenamiento libre" },
  { dia: "Sábado", fecha: "22 Nov 2025", actividad: "Eliminatorias — Series A y B" },
  { dia: "Domingo", fecha: "23 Nov 2025", actividad: "Finales — Todas las categorías" },
];

const categorias = [
  "Senior Masculino", "Senior Femenino",
  "Sub-23 Masculino", "Sub-23 Femenino",
  "Juvenil Masculino", "Juvenil Femenino",
  "Master A", "Master B", "Master C",
];
---

<Layout title="CAR 2025 — Campeonato Argentino de Remo">
  <!-- Hero -->
  <div class="bg-gradient-to-r from-[#0B2545] to-[#134074] text-white py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-[#EFC050] text-sm font-semibold uppercase tracking-widest mb-3">Campeonato Argentino de Remo</div>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">CAR 2025</h1>
      <p class="text-gray-300 text-lg mb-6">Tigre, Buenos Aires — Noviembre 2025</p>
      <div class="flex flex-wrap gap-4">
        <div class="bg-white/10 rounded-lg px-4 py-3 text-center">
          <div class="text-2xl font-bold text-[#EFC050]">3</div>
          <div class="text-xs text-gray-300 mt-0.5">Días de competencia</div>
        </div>
        <div class="bg-white/10 rounded-lg px-4 py-3 text-center">
          <div class="text-2xl font-bold text-[#EFC050]">{categorias.length}</div>
          <div class="text-xs text-gray-300 mt-0.5">Categorías</div>
        </div>
        <div class="bg-white/10 rounded-lg px-4 py-3 text-center">
          <div class="text-2xl font-bold text-[#EFC050]">+30</div>
          <div class="text-xs text-gray-300 mt-0.5">Clubes participantes</div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      <div class="lg:col-span-2 space-y-8">
        <!-- Programa -->
        <section class="bg-white rounded-xl shadow p-8">
          <h2 class="text-xl font-bold text-[#0B2545] mb-6">Programa de competencia</h2>
          <div class="space-y-4">
            {programa.map(p => (
              <div class="flex gap-5 items-start">
                <div class="w-24 shrink-0 text-center bg-[#0B2545] text-white rounded-lg py-2 px-3">
                  <div class="text-xs text-[#EFC050]">{p.dia}</div>
                  <div class="text-sm font-bold mt-0.5">{p.fecha.split(" ").slice(0,2).join(" ")}</div>
                </div>
                <div class="pt-1">
                  <p class="font-medium text-[#0B2545]">{p.actividad}</p>
                  <p class="text-xs text-gray-400 mt-0.5">{p.fecha}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Categorías -->
        <section class="bg-white rounded-xl shadow p-8">
          <h2 class="text-xl font-bold text-[#0B2545] mb-6">Categorías</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {categorias.map(cat => (
              <div class="bg-gray-50 border border-gray-100 rounded-lg px-4 py-2.5 text-sm font-medium text-[#0B2545]">
                {cat}
              </div>
            ))}
          </div>
        </section>

        <!-- Ranking de clubes -->
        <section class="bg-white rounded-xl shadow overflow-hidden">
          <div class="px-8 py-5 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-xl font-bold text-[#0B2545]">Ranking de clubes</h2>
            <span class="text-xs text-gray-400">Puntuación acumulada</span>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 text-xs font-semibold text-gray-500 uppercase tracking-wider">
                <tr>
                  <th class="px-6 py-3 text-left w-12">#</th>
                  <th class="px-6 py-3 text-left">Club</th>
                  <th class="px-4 py-3 text-center"><span class="text-[#EFC050]">●</span></th>
                  <th class="px-4 py-3 text-center"><span class="text-gray-400">●</span></th>
                  <th class="px-4 py-3 text-center"><span class="text-amber-700">●</span></th>
                  <th class="px-6 py-3 text-right font-bold text-[#0B2545]">Pts</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                {rankingClubes.map(r => (
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4">
                      {r.posicion === 1 && <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-[#EFC050] text-white text-xs font-bold shadow-sm">1</span>}
                      {r.posicion === 2 && <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-gray-400 text-white text-xs font-bold shadow-sm">2</span>}
                      {r.posicion === 3 && <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-amber-700 text-white text-xs font-bold shadow-sm">3</span>}
                      {r.posicion > 3 && <span class="text-gray-400 font-medium">{r.posicion}</span>}
                    </td>
                    <td class="px-6 py-4 font-semibold text-[#0B2545]">{r.club}</td>
                    <td class="px-4 py-4 text-center text-gray-700">{r.oros}</td>
                    <td class="px-4 py-4 text-center text-gray-700">{r.platas}</td>
                    <td class="px-4 py-4 text-center text-gray-700">{r.bronces}</td>
                    <td class="px-6 py-4 text-right font-bold text-[#0B2545]">{r.puntos}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="px-8 py-4 bg-gray-50 border-t border-gray-100">
            <p class="text-xs text-gray-400">El ranking se actualiza tras cada final disputada.</p>
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <div class="space-y-4">
        <div class="bg-white rounded-xl shadow p-6">
          <h3 class="font-bold text-[#0B2545] mb-4">Documentos CAR 2025</h3>
          <ul class="space-y-3">
            {[
              { label: "Programa oficial", href: "#" },
              { label: "Lista de inscriptos", href: "#" },
              { label: "Resultados finales", href: "#" },
              { label: "Reglamento de competencia", href: "/biblioteca/reglamentos" },
              { label: "Formulario de inscripción", href: "/biblioteca/formularios" },
            ].map(d => (
              <li>
                <a href={d.href} class="flex items-center gap-2 text-sm text-[#134074] hover:text-[#0B2545] transition-colors font-medium">
                  <svg class="w-4 h-4 text-[#EFC050] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  {d.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-[#0B2545] text-white rounded-xl p-6">
          <h3 class="font-bold mb-2">Sede</h3>
          <p class="text-gray-300 text-sm leading-relaxed">
            Tigre Rowing Club<br/>
            Tigre, Buenos Aires<br/>
            Argentina
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>
